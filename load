		CoreGui:FindFirstChild("EtherHubAutoFarm"),
		playerGui:FindFirstChild("EtherHub"),
		CoreGui:FindFirstChild("EtherHub"),
	}

	for _, gui in ipairs(targets) do
		if gui and oldStates[gui] == nil then
			if gui:IsA("ScreenGui") then
				oldStates[gui] = gui.Enabled
				gui.Enabled = false
			elseif gui:IsA("GuiObject") then
				oldStates[gui] = gui.Visible
				gui.Visible = false
			end
		end
	end

	return function()
		for gui, state in pairs(oldStates) do
			if gui and gui.Parent then
				if gui:IsA("ScreenGui") then
					gui.Enabled = state
				elseif gui:IsA("GuiObject") then

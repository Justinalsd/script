function getCombinedRewardScore(entry, profile)
	if type(entry) ~= "table" or not entry.frame then
		return -math.huge, 0, 0, 0, 0
	end

	local card = entry.frame
	local tierWeight = math.max(1, getRewardCardTierWeight(card))
	local level, damage, health = getUiRewardPower(card)

	local cardData = nil
	if type(profile) == "table" and type(profile.cards) == "table" then
		cardData = profile.cards[entry.index]
	end

	if type(cardData) == "table" then
		tierWeight = math.max(tierWeight, getServerRewardTierWeight(cardData))
		level = math.max(level, getDeepRewardNumber(cardData, {
			level = true,
			lvl = true,
		}))
		damage = math.max(damage, getDeepRewardNumber(cardData, {
			damage = true,
			dmg = true,
			atk = true,
			attack = true,
			power = true,
		}))
		health = math.max(health, getDeepRewardNumber(cardData, {
			health = true,
			hp = true,
			life = true,
		}))
	end

	local score = calcStealRewardScore(tierWeight, level, damage, health)
	local petName = nil
	if type(cardData) == "table" then
		petName = getRewardProfilePetName(cardData) or cardData.name or cardData.title
	end
	if not petName or tostring(petName) == "" then
		petName = getRewardPetNameFromCard(card)
	end

	local targetMatch = getStealPriorityMatchFromEntry(entry, profile)
	if targetMatch then
		petName = targetMatch
		score += STEAL_PRIORITY_NAME_SCORE
	else
		score += getStealPriorityNameScore(petName)
	end

	if rewardUseSkill() then
		score += getSkillScoreByPetName(petName)
	end
	return score, tierWeight, level, damage, health
end

function chooseBestRewardEntry(cards)
	if type(cards) ~= "table" or #cards == 0 then
		return nil, "no_cards"
	end

	local profile, matchReason = findMatchingRewardProfile(cards)
	if profile and type(profile.cards) == "table" then
		local bestEntry = nil
		local bestScore = -math.huge

		for _, entry in ipairs(cards) do
			local s = getCombinedRewardScore(entry, profile)

			if s > bestScore then
				bestScore = s
				bestEntry = entry
			end
		end

		if bestEntry and bestEntry.frame then
			updateLastStolenPetFromRewardEntry(bestEntry, profile, "GetData Profile", bestScore)
			local petName = lastStolenPet and lastStolenPet.Name or "Unknown"
			setStatus("Reward: " .. tostring(petName) .. " | GetData profile", Color3.fromRGB(0, 255, 150))
			return bestEntry, "getdata_profile_" .. tostring(matchReason) .. "_reward_" .. tostring(petName) .. "_score_" .. tostring(bestScore)
		end
	end

	table.sort(cards, function(a, b)
		return oldRewardScore(a.frame) > oldRewardScore(b.frame)
	end)

	if cards[1] and cards[1].frame then
		updateLastStolenPetFromRewardEntry(cards[1], nil, "UI Card", oldRewardScore(cards[1].frame))
		local petName = lastStolenPet and lastStolenPet.Name or "Unknown"
		setStatus("Reward: " .. tostring(petName) .. " | UI fallback", Color3.fromRGB(255, 200, 80))
		return cards[1], "ui_fallback_" .. tostring(matchReason) .. "_reward_" .. tostring(petName)
	end

	return nil, "ui_fallback_no_card_" .. tostring(matchReason)
end

function directClaimRewardIndex(index, reason)
	index = tonumber(index)
	if not index or index <= 0 then
		return false, "bad_index"
	end
	if not R_ClaimBattleRewards then
		return false, "remote_missing"
	end

	setStatus("Direct claiming reward #" .. tostring(index) .. "...", Color3.fromRGB(100, 200, 255))

	local ok, result = invokeRemote(R_ClaimBattleRewards, {index})
	if ok and type(result) == "table" then
		if type(result.data) == "table" then
			cacheChestProfilesFromData(result.data)
		end
		if result.success == true then

			return true, "direct_claim_success"
		end
		return false, result.reason or result.error or "server_rejected"
	elseif ok and result == true then
		return true, "direct_claim_true"
	elseif ok and result ~= false and result ~= nil then
		return true, "direct_claim_nonfalse"
	end

	return false, tostring(result or "remote_failed")
end

function selectBestRewardUI()
	if not autoFarmEnabled then return false, "auto_farm_off" end

	local restoreUI = rewardHideEtherHubUI()
	local okReturn, modeReturn = false, "failed"


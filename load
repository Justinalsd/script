			if not firstButton and cur:IsA("GuiButton") and isVisibleOnScreen(cur) then
				firstButton = cur
			end
		end
		cur = cur.Parent
	end

	return firstButton or obj
end

function expandGuiHitboxForClick(obj, kind)
	if getgenv().EtherHubClickExpandEnabled == false then
		return function() end, obj
	end

	getgenv().EtherHubPermanentClickExpand = (getgenv().EtherHubPermanentClickExpand ~= false)
	getgenv().EtherHubExpandedButtonCache = getgenv().EtherHubExpandedButtonCache or setmetatable({}, { __mode = "k" })

	kind = tostring(kind or ""):lower()
	local expandObj = resolveExpandableClickObject(obj, kind)

	if kind == "matchspeed" and expandObj then
		local option = expandObj:FindFirstChild("Option", true)
		if option and option:IsA("TextLabel") and tostring(option.Text) == "1x" then
			return function() end, obj
		end
	end

	if not expandObj or not expandObj:IsA("GuiObject") or not isVisibleOnScreen(expandObj) then
		return function() end, obj
	end

	local parent = expandObj.Parent
	if not parent or not parent:IsA("GuiObject") then
		return function() end, obj
	end

	local parentSize = parent.AbsoluteSize
	if parentSize.X <= 0 or parentSize.Y <= 0 then
		return function() end, obj
	end

	local extraX, extraY = getClickExpandAmount(kind)
	if extraX <= 0 and extraY <= 0 then
		return function() end, obj
	end

	local cache = getgenv().EtherHubExpandedButtonCache
	local saved = cache[expandObj]
	if saved and saved.expanded == true then
		if kind == "matchspeed" then
			cache[expandObj] = nil
			pcall(function()
				if expandObj and expandObj.Parent then
					expandObj.Size = saved.oldSize
					expandObj.Position = saved.oldPosition
					expandObj.AnchorPoint = saved.oldAnchor
					expandObj.ZIndex = saved.oldZ
					expandObj.Active = saved.oldActive
					if expandObj:IsA("GuiButton") and saved.oldAutoButtonColor ~= nil then
						expandObj.AutoButtonColor = saved.oldAutoButtonColor
					end
				end
			end)
		else
			pcall(function()
				expandObj.ZIndex = math.max(tonumber(expandObj.ZIndex) or 1, 999)
				expandObj.Active = true
				if expandObj:IsA("GuiButton") then
					expandObj.AutoButtonColor = false
				end
			end)
			return function() end, obj
		end
	end

	local oldSize = expandObj.Size
	local oldPosition = expandObj.Position
	local oldAnchor = expandObj.AnchorPoint
	local oldZ = expandObj.ZIndex
	local oldActive = expandObj.Active
	local oldAutoButtonColor = expandObj:IsA("GuiButton") and expandObj.AutoButtonColor or nil

	local absPos = expandObj.AbsolutePosition
	local absSize = expandObj.AbsoluteSize
	local parentAbs = parent.AbsolutePosition
	local center = absPos + Vector2.new(absSize.X * 0.5, absSize.Y * 0.5)
	local newW = math.max(1, absSize.X + extraX)
	local newH = math.max(1, absSize.Y + extraY)

	local ok = pcall(function()
		expandObj.AnchorPoint = Vector2.new(0.5, 0.5)
		expandObj.Position = UDim2.fromScale(
			(center.X - parentAbs.X) / parentSize.X,
			(center.Y - parentAbs.Y) / parentSize.Y
		)
		expandObj.Size = UDim2.fromOffset(newW, newH)
		expandObj.ZIndex = math.max(tonumber(oldZ) or 1, 999)
		expandObj.Active = true
		if expandObj:IsA("GuiButton") then
			expandObj.AutoButtonColor = false
		end
	end)

	if not ok then
		return function() end, obj
	end

	cache[expandObj] = {
		expanded = true,
		kind = kind,
		oldSize = oldSize,
		oldPosition = oldPosition,
		oldAnchor = oldAnchor,
		oldZ = oldZ,
		oldActive = oldActive,
		oldAutoButtonColor = oldAutoButtonColor,
	}

	local function restore()
		-- Keep Claim / Skip / Steal expanded permanently, but MatchSpeed 2x must shrink back after clicking.
		if getgenv().EtherHubPermanentClickExpand ~= false and kind ~= "matchspeed" then
			return
		end

		local data = cache[expandObj]
		cache[expandObj] = nil
		pcall(function()
			if expandObj and expandObj.Parent then
				expandObj.Size = data and data.oldSize or oldSize
				expandObj.Position = data and data.oldPosition or oldPosition
				expandObj.AnchorPoint = data and data.oldAnchor or oldAnchor
				expandObj.ZIndex = data and data.oldZ or oldZ
				expandObj.Active = data and data.oldActive or oldActive
				local autoColor = data and data.oldAutoButtonColor or oldAutoButtonColor
				if expandObj:IsA("GuiButton") and autoColor ~= nil then
					expandObj.AutoButtonColor = autoColor
				end
			end
		end)
	end

	return restore, obj
end

function sendTouchOrMouseClick(x, y, rightClick)
	local okTouch = false
	local okMouse = false

	if isMobile then
		okTouch = pcall(function()
			VirtualInputManager:SendTouchEvent(1, Enum.UserInputState.Begin, x, y)
			task.wait(0.055)
			VirtualInputManager:SendTouchEvent(1, Enum.UserInputState.End, x, y)
		end)
		task.wait(0.045)
	end

	local btn = rightClick and 1 or 0
	okMouse = pcall(function()
		VirtualInputManager:SendMouseMoveEvent(x, y, game)
		task.wait(0.045)
		VirtualInputManager:SendMouseButtonEvent(x, y, btn, true, game, 1)
		task.wait(0.045)
		VirtualInputManager:SendMouseButtonEvent(x, y, btn, false, game, 1)
	end)

	task.wait(isMobile and 0.08 or 0.065)
	return okTouch or okMouse
end

function tryGuiActivate(obj)
	if not obj or not obj:IsA("GuiButton") then
		return false
	end

	local ok = pcall(function()
		obj:Activate()
	end)

	if ok then
		task.wait(0.08)
		return true
	end

	return false
end

function fireGuiButtonActivated(obj)
	if not obj or not obj:IsA("GuiButton") then
		return false
	end

	local did = false

	if typeof(firesignal) == "function" then
		local ok1 = pcall(function()
			firesignal(obj.Activated)
		end)
		did = did or ok1

		local ok2 = pcall(function()
			firesignal(obj.MouseButton1Click)
		end)
		did = did or ok2
	end

	if typeof(getconnections) == "function" then
		pcall(function()
			for _, con in ipairs(getconnections(obj.Activated)) do
				if con and con.Enabled ~= false then
					pcall(function()
						if typeof(con.Fire) == "function" then
							con:Fire()
						elseif typeof(con.Function) == "function" then
							con.Function()
						end
					end)
					did = true
				end
			end
		end)

		pcall(function()
			for _, con in ipairs(getconnections(obj.MouseButton1Click)) do
				if con and con.Enabled ~= false then
					pcall(function()
						if typeof(con.Fire) == "function" then
							con:Fire()
						elseif typeof(con.Function) == "function" then
							con.Function()
						end
					end)
					did = true
				end
			end
		end)
	end

	local ok3 = tryGuiActivate(obj)
	did = did or ok3

	if did then
		task.wait(0.1)
	end

	return did
end

function safeClick(obj, rightClick)
	if clickLock or not obj or not isVisibleOnScreen(obj) then return false end
	clickLock = true
	clickLockStartedAt = tick()

	local ok = false
	local finished = false

	task.spawn(function()

		local activated = false
		if not isMobile then
			activated = tryGuiActivate(obj)
		end
		local x, y = getGuiClickPoint(obj, "center_no_inset")
		local pointed = sendTouchOrMouseClick(x, y, rightClick)
		ok = activated or pointed
		finished = true
	end)

	local t0 = tick()
	while not finished and tick() - t0 < 0.9 do
		task.wait()
	end

	if not finished then
		ok = false
	end

	task.wait(0.08)
	clickLock = false
	clickLockStartedAt = 0
	return ok
end

function robustClickModes(obj, rightClick, modes)
	if clickLock or not obj or not isVisibleOnScreen(obj) then return false end
	clickLock = true
	clickLockStartedAt = tick()

	local success = false
	modes = modes or {"center_no_inset"}

	for _, mode in ipairs(modes) do
		if not obj or not isVisibleOnScreen(obj) then break end

		local x, y = getGuiClickPoint(obj, mode)
		local ok = sendTouchOrMouseClick(x, y, rightClick)
		success = success or ok

		task.wait(isMobile and 0.20 or 0.12)
	end

	clickLock = false
	clickLockStartedAt = 0
	return success
end


		if keepChest then

			setStatus("Keep chest visible. Waiting for Skip...", Color3.fromRGB(255, 205, 70))
			return true
		end
		return false
	end

	setStatus("Skip visible. Clicking safe Skip target...", Color3.fromRGB(0, 255, 150))

	local modes = {
		"skip_center_tuned",
		"skip_lower_tuned",
		"skip_bottom_tuned",
		"center_no_inset",
		"center_down_8_no_inset",
		"center_down_12_no_inset",
		"lower_no_inset",
		"upper_no_inset",
	}

	for attempt = 1, SKIP_CLICK_RETRY do
		if not autoFarmEnabled then return false end
		if not skip or not isVisibleOnScreen(skip) then
			skip, reason = getKeepChestSkipButton()
		end
		if not skip then
			return true
		end

		local ok = clickByPixelsOnlyExpanded(skip, false, modes, "skip")
		task.wait(isMobile and 0.26 or 0.18)
		if not autoFarmEnabled then return false end

		local stillKeepChest = getKeepChestFrame() ~= nil
		local stillSkip = select(1, getKeepChestSkipButton()) ~= nil
		if clickClaimIfVisible() then
			return true
		end
		if ok and (not stillKeepChest or not stillSkip) then
			return true
		end
	end

	return true
end

function handleClaimSkip()
	if not autoFarmEnabled then return false end

	if clickClaimIfVisible() then
		return true
	end

	if clickSkipIfVisible() then
		return true
	end

	return false
end


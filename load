function textLooksLikeSkip(obj)
	local ok, value = pcall(function()
		if obj:IsA("TextButton") or obj:IsA("TextLabel") or obj:IsA("TextBox") then
			return tostring(obj.Text or "")
		end
		return ""
	end)
	if not ok then return false end
	value = tostring(value or ""):lower():gsub("%s+", "")
	return value == "skip" or value:find("skip", 1, true) ~= nil
end

function nameLooksLikeSkip(obj)
	local n = tostring(obj and obj.Name or ""):lower()
	return n == "skip" or n:find("skip", 1, true) ~= nil
end

function isBuyLike(obj)
	local cur = obj
	while cur do
		local n = tostring(cur.Name or ""):lower()
		if n:find("buy", 1, true) or n:find("price", 1, true) or n:find("purchase", 1, true) or n:find("robux", 1, true) then
			return true
		end
		if cur:IsA("GuiObject") and textLooksLikeSkip(cur) then
			return false
		end
		cur = cur.Parent
	end
	return false
end

function getKeepChestSkipButton()
	local keepChest = getKeepChestFrame()
	if not keepChest then
		return nil, "keepChest_not_visible"
	end

	local exactSkip = keepChest:FindFirstChild("Skip")

	if exactSkip and exactSkip:IsA("TextButton") and isVisibleOnScreen(exactSkip) and not isBuyLike(exactSkip) then
		return exactSkip, "exact_KeepChest_Skip_TextButton"
	end

	local bestText = nil
	local bestArea = math.huge
	for _, obj in ipairs(keepChest:GetDescendants()) do
		if obj:IsA("GuiObject") and isVisibleOnScreen(obj) and textLooksLikeSkip(obj) and not isBuyLike(obj) then
			local area = obj.AbsoluteSize.X * obj.AbsoluteSize.Y
			if area > 0 and area < bestArea then
				bestArea = area
				bestText = obj
			end
		end
	end
	if bestText then
		return bestText, "visible_skip_text_center"
	end

	if exactSkip and exactSkip:IsA("GuiObject") and isVisibleOnScreen(exactSkip) and not isBuyLike(exactSkip) then
		local clickZone = exactSkip:FindFirstChild("_ClickZone", true)
		if clickZone and clickZone:IsA("GuiObject") and isVisibleOnScreen(clickZone) and not isBuyLike(clickZone) then
			return clickZone, "exact_KeepChest_Skip_ClickZone"
		end

		local childBtn = exactSkip:FindFirstChildWhichIsA("GuiButton", true)
		if childBtn and isVisibleOnScreen(childBtn) and not isBuyLike(childBtn) then
			return childBtn, "exact_KeepChest_Skip_child_button"
		end

		local s = exactSkip.AbsoluteSize
		local ks = keepChest.AbsoluteSize
		local tooHuge = ks.X > 0 and ks.Y > 0 and (s.X > ks.X * 0.75 or s.Y > ks.Y * 0.30)
		if not tooHuge then
			return exactSkip, "exact_KeepChest_Skip_guiobject"
		end
	end

	for _, obj in ipairs(keepChest:GetDescendants()) do
		if obj:IsA("GuiObject") and isVisibleOnScreen(obj) and nameLooksLikeSkip(obj) and not isBuyLike(obj) then
			return obj, "fallback_KeepChest_skip_named_guiobject"
		end
	end

	return nil, "skip_not_found_or_not_visible_yet"
end


	Prismatic = 11,
	Divine = 10,
	Exotic = 9,
	Exclusive = 8,
	Mythic = 7,
	Legendary = 6,
	Epic = 5,
	Rare = 4,
	Uncommon = 2,
	Common = 1,
	[""] = 0,
}

TIER_BASE_SCORE = 1e150
WEIGHT_LEVEL    = 6000
WEIGHT_DAMAGE   = 80
WEIGHT_HEALTH   = 10

REWARD_POWER_WEIGHT = {
	LEVEL = WEIGHT_LEVEL,
	DAMAGE = WEIGHT_DAMAGE,
	HEALTH = WEIGHT_HEALTH,
	AMOUNT_PETXP = 0,

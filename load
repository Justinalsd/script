	return count
end

function getPetScore(data, petId)
	local details = data and data.petDetails and data.petDetails[petId]
	local basic = data and data.pets and data.pets[petId]

	local tierName = nil
	local tierRank = 0
	local score = 0
	local level = 0
	local atk = 0
	local hp = 0
	local sellXp = 0

	if type(details) == "table" then
		tierName = details.tierName or details.tier
		tierRank = tonumber(details.tierRank) or 0
		score = tonumber(details.score) or 0
		level = tonumber(details.level) or 0
		atk = tonumber(details.atk) or 0
		hp = tonumber(details.hp) or 0
		sellXp = tonumber(details.sellXpValue or details.sellXpCap) or 0
	end

	if type(basic) == "table" then
		level = math.max(level, tonumber(basic.level) or 0)
		tierName = tierName or basic.tierName or basic.tier
		sellXp = math.max(sellXp, tonumber(basic.sellXpCap) or 0)
	end

	local tierScore = TIER_SCORE[tostring(tierName or "Common")] or (tierRank * 100000)
	return tierScore + (score * 1000) + (level * 120) + (atk * 10) + hp + (sellXp * 0.01)
end


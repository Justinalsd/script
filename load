function normalizeKey(k)
	return tostring(k or ""):lower():gsub("[%s_%-]", "")
end

function scanNumbersDeep(tbl, out, prefix)
	if type(tbl) ~= "table" then return end
	prefix = prefix or ""

	for k, v in pairs(tbl) do
		local key = normalizeKey(k)
		local fullKey = prefix ~= "" and (prefix .. "." .. key) or key

		if type(v) == "number" then
			out[fullKey] = (out[fullKey] or 0) + v
		elseif type(v) == "boolean" then
			out[fullKey] = (out[fullKey] or 0) + (v and 1 or 0)
		elseif type(v) == "table" then
			scanNumbersDeep(v, out, fullKey)
		end
	end
end

function scanTextDeep(tbl, parts)
	if type(tbl) ~= "table" then return end

	for k, v in pairs(tbl) do
		table.insert(parts, tostring(k):lower())

		if type(v) == "string" then
			table.insert(parts, v:lower())
		elseif type(v) == "table" then
			scanTextDeep(v, parts)
		end
	end
end


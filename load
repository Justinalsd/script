function clickClaimIfVisible()
	if not autoFarmEnabled then return false end

	local claim, reason = getRevealClaimButton()
	if not claim then
		return false
	end

	if tick() - lastClaimCheckClickAt < (isMobile and 0.45 or 0.18) then
		return true
	end
	lastClaimCheckClickAt = tick()

	for attempt = 1, CLAIM_CLICK_RETRY do
		if not autoFarmEnabled then return false end
		if not claim or not isVisibleOnScreen(claim) then
			claim, reason = getRevealClaimButton()
		end
		if not claim then
			break
		end

		setStatus("Claim/check visible. Clicking...", Color3.fromRGB(0, 255, 150))
		local ok = clickClaimTarget(claim, reason)

		task.wait(0.18)
		if not autoFarmEnabled then return false end

		local stillThere = select(1, getRevealClaimButton()) ~= nil
		if ok and not stillThere then
			return true
		end
	end

	return true
end


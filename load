UserInputService.InputBegan:Connect(function(input, gpe)
    local isKeyboard = input.UserInputType == Enum.UserInputType.Keyboard
    if isKeyboard and capturingAutoFarmKeybind then
        if input.KeyCode == Enum.KeyCode.Escape or input.KeyCode == Enum.KeyCode.RightShift then
            capturingAutoFarmKeybind = false
            if keyControl then keyControl.redraw(false) end
            setStatus("Keybind unchanged", Color3.fromRGB(255, 170, 0))
            return
        end
        if input.KeyCode ~= Enum.KeyCode.Unknown then
            local keyName = input.KeyCode.Name
            coreSet("autoFarmKeybind", keyName)
            capturingAutoFarmKeybind = false
            if keyControl then keyControl.redraw(false) end
            setStatus("Auto Farm key: " .. keyName, Color3.fromRGB(0, 220, 255))
            return
        end
    end
    if gpe then return end
    local keybind = tostring(coreGet("autoFarmKeybind", "F"))
    if isKeyboard and input.KeyCode.Name == keybind then
        local newState = not (coreGet("autoFarmEnabled", false) == true)
        coreSet("autoFarmEnabled", newState)
        if controls["Auto Farm"] and controls["Auto Farm"].set then controls["Auto Farm"].set(newState) end
        setStatus("Auto Farm: " .. (newState and "ON" or "OFF") .. " [" .. keybind .. "]", newState and Color3.fromRGB(0, 255, 150) or Color3.fromRGB(255, 170, 0))
        return
    end
    if isKeyboard and input.KeyCode == Enum.KeyCode.RightShift then
        setUIVisible(not uiVisible)
    end
end)


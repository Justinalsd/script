function waitForPlayReady(timeout)
	timeout = tonumber(timeout) or 8
	local t0 = tick()
	local visibleSince = nil

	while tick() - t0 < timeout do
		if not autoFarmEnabled then
			return false
		end

		if isChestOpenUiActive() then
			visibleSince = nil
			setStatus("Chest UI open. Waiting...", Color3.fromRGB(255, 170, 0))
			if autoOpenChestEnabled and type(chestAutoOpenOnce) == "function" then
				task.spawn(function()
					pcall(chestAutoOpenOnce)
				end)
			end
			task.wait(0.25)
			continue
		end

		if isPlayReady() then
			visibleSince = visibleSince or tick()
			if tick() - visibleSince >= PLAY_STABLE_READY_TIME then
				return true
			end
			setStatus("Play visible. Stabilizing...", Color3.fromRGB(100, 150, 255))
		else
			visibleSince = nil
			setStatus("Waiting for Play button...", Color3.fromRGB(100, 150, 255))
		end
		task.wait(0.08)
	end

	return false
end



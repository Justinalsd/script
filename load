local function getNameList(kind)
    -- Uses the direct normalized storage system, while keeping the current UI unchanged.
    safeCall(function()
        if normalizePetNameLists then normalizePetNameLists() end
    end)

    local storage = kind == "steal" and stealPriorityPets or sellLockPets
    local list = {}

    if type(getPetNameStorageList) == "function" then
        list = getPetNameStorageList(storage) or {}
    elseif type(storage) == "table" then
        for normalized in pairs(storage) do
            list[#list + 1] = {
                key = normalized,
                name = (type(resolvePetName) == "function" and (resolvePetName(normalized) or normalized)) or normalized,
                locked = true,
            }
        end
    end

    if type(list) ~= "table" then return {} end
    table.sort(list, function(a, b) return tostring(a.name or a.key):lower() < tostring(b.name or b.key):lower() end)
    return list
end


end

function prunePetNameLevelLocks(data, shouldSave)
	normalizePetNameLevelLock()

	if type(data) ~= "table" or type(data.pets) ~= "table" then
		return false
	end

	local aliveKeys = {}
	for petId in pairs(data.pets) do
		local key = getPetNameLevelLockKey(data, tostring(petId))
		if key and tostring(key) ~= "" then
			aliveKeys[key] = true
		end
	end

	local changed = false
	for key, value in pairs(petNameLevelLock) do
		if value ~= true or aliveKeys[key] ~= true then
			petNameLevelLock[key] = nil
			changed = true
		end
	end

	if changed and shouldSave == true then
		saveConfig()
	end

	return changed
end

function isPetNameLevelLocked(data, petId)
	normalizePetNameLevelLock()
	return petNameLevelLock[getPetNameLevelLockKey(data, petId)] == true
end

function isSellTierLocked(data, petId)
	if type(sellTierLock) ~= "table" then return false end

	local tierName = getPetTierName(data, petId)
	for lockedTier, locked in pairs(sellTierLock) do
		if locked == true and tostring(tierName):lower() == tostring(lockedTier):lower() then
			return true
		end
	end

	return false
end

function isSellProtectedPet(data, petId)
	return isSellTierLocked(data, petId) or isPetNameLevelLocked(data, petId) or isPetSellLocked(getPetDisplayName(data, petId))
end

function getWeakestSellablePet(data)
	if type(data) ~= "table" or type(data.pets) ~= "table" then return nil end

	local equipped = buildEquippedSet(data)
	local weakestId = nil
	local lowestScore = math.huge

	forEachPetId(data, function(petId)
		if not equipped[petId] and not isSellProtectedPet(data, petId) then
			local s = getPetScore(data, petId)
			if s < lowestScore then
				lowestScore = s
				weakestId = petId
			end
		end
	end)

	return weakestId, lowestScore
end


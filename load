function getStealCoreCriteriaState()
	normalizeStealCriteria()

	local states = {
		Tier = stealUseTier ~= false and getgenv().EtherHubStealUseTier ~= false,
		Level = stealUseLevel ~= false and getgenv().EtherHubStealUseLevel ~= false,
		Damage = stealUseDamage ~= false and getgenv().EtherHubStealUseDamage ~= false,
		Health = stealUseHealth ~= false and getgenv().EtherHubStealUseHealth ~= false,
	}

	local enabled, total = 0, 0
	for _, value in pairs(states) do
		total += 1
		if value then enabled += 1 end
	end

	local useDefault = enabled == 0 or enabled == total
	return states, useDefault, enabled, total
end

function isStealCoreCriterionActive(name)
	local states, useDefault = getStealCoreCriteriaState()
	if useDefault then
		return true
	end
	return states[name] == true
end

function getStealSkillFilterState()
	normalizeStealSkillCriteria()

	local enabled, total = 0, 0
	for skillName in pairs(STEAL_SKILL_DEFAULTS) do
		total += 1
		if stealSkillCriteria[skillName] == true then
			enabled += 1
		end
	end

	if enabled == 0 then
		return "none", enabled, total
	elseif enabled == total then
		return "all", enabled, total
	end

	return "subset", enabled, total
end

function rewardUseTier()
	return isStealCoreCriterionActive("Tier")
end

function rewardUseLevel()
	return isStealCoreCriterionActive("Level")
end

function rewardUseDamage()
	return isStealCoreCriterionActive("Damage")
end

function rewardUseHealth()
	return isStealCoreCriterionActive("Health")
end

function calcStealRewardScore(tierWeight, level, damage, health)
	local score = 0

	if rewardUseTier() then
		score = score + ((tonumber(tierWeight) or 0) * TIER_BASE_SCORE)
	end
	if rewardUseLevel() then
		score = score + ((tonumber(level) or 0) * WEIGHT_LEVEL)
	end
	if rewardUseDamage() then
		score = score + ((tonumber(damage) or 0) * WEIGHT_DAMAGE)
	end
	if rewardUseHealth() then
		score = score + ((tonumber(health) or 0) * WEIGHT_HEALTH)
	end

	return score
end

function normText(v)
	return tostring(v or ""):lower():gsub("%s+", ""):gsub("[^%w]", "")
end


SKILL_BASE_SCORE = 25000000000
SKILL_EXTRA_SCORE = 750000000

function rewardUseSkill()
	if stealUseSkill == false or getgenv().EtherHubStealUseSkill == false then
		return false
	end

	local state = getStealSkillFilterState()
	return state == "subset"
end

function loadEtherHubPetSkillFile()
	if type(getgenv().EtherHubPetSkills) == "table" then
		return true, "already_loaded"
	end
	local url = tostring(getgenv().EtherHubPetSkillUrl or ETHERHUB_PET_SKILL_URL or "")
	if url == "" or url == "PUT_PET_SKILL_RAW_URL_HERE" then
		return false, "skill_url_not_set"
	end
	local ok, source = pcall(function()
		return game:HttpGet(url)
	end)
	if not ok or type(source) ~= "string" or source == "" then
		return false, "skill_http_failed"
	end
	local fn, compileErr = loadstring(source)
	if type(fn) ~= "function" then
		return false, compileErr or "skill_compile_failed"
	end
	local runOk, runErr = pcall(fn)
	if not runOk then
		return false, runErr or "skill_run_failed"
	end
	return type(getgenv().EtherHubPetSkills) == "table", "skill_loaded"
end

pcall(loadEtherHubPetSkillFile)

function getPetSkillDatabase()
	if type(getgenv().EtherHubPetSkills) ~= "table" then
		pcall(loadEtherHubPetSkillFile)
	end
	return type(getgenv().EtherHubPetSkills) == "table" and getgenv().EtherHubPetSkills or {}
end

function getPetSkillRecordByName(petName)
	local db = getPetSkillDatabase()
	local raw = tostring(petName or "")
	if raw == "" then return nil end
	if type(db[raw]) == "table" then return db[raw], raw end
	local n = normText(raw)
	for name, info in pairs(db) do
		if normText(name) == n or normText(info and info.title) == n then
			return info, name
		end
	end
	return nil
end

function detectRewardPetNameFromText(text)
	local blob = normText(text)
	if blob == "" then return nil end
	local db = getPetSkillDatabase()
	local bestName, bestLen = nil, 0
	for name, info in pairs(db) do
		local n1 = normText(name)
		local n2 = normText(info and info.title)
		if n1 ~= "" and blob:find(n1, 1, true) and #n1 > bestLen then
			bestName, bestLen = name, #n1
		end
		if n2 ~= "" and blob:find(n2, 1, true) and #n2 > bestLen then
			bestName, bestLen = name, #n2
		end
	end
	return bestName
end

function getRewardPetNameFromCard(card)
	local raw, blob = getRewardCardText(card)
	return detectRewardPetNameFromText(raw or blob or "")
end

function getRewardPetName(card)
	return getRewardPetNameFromCard(card)
end

function abilitySkillTypes(ability)
	local result = {}
	if type(ability) ~= "table" then return result end
	local effect = normText(ability.effect)
	local label = normText(ability.label)
	local target = normText(ability.target)
	local trigger = normText(ability.trigger)
	local function add(name)
		if STEAL_SKILL_DEFAULTS[name] ~= nil then result[name] = true end
	end
	if effect == "dealdamage" then add("Damage") end
	if effect == "splash" then add("Damage"); add("Splash") end
	if effect == "freeze" or effect == "stun" then add("Freeze") end
	if effect == "stealatk" then add("StealAtk") end
	if effect == "steal" then add("Steal") end
	if effect == "heal" then add("Heal") end
	if effect == "summon" then add("Summon") end
	if effect == "buffatk" then add("BuffAtk") end
	if effect == "buffhp" then add("BuffHp") end
	if effect == "buffboth" or effect == "buff_both" then add("BuffBoth") end
	if effect == "debuffatk" then add("DebuffAtk") end
	if effect == "debuffboth" or effect == "debuff_both" then add("DebuffBoth") end
	if effect == "clone" then add("Clone") end
	if effect == "devour" then add("Devour") end
	if effect == "copyabilityset" or effect == "copyability" then add("CopySkill") end
	if label:find("guard", 1, true) or label:find("shield", 1, true) or target:find("guard", 1, true) or trigger:find("defend", 1, true) then add("Shield") end
	return result
end

function getSkillScoreByPetName(petName)
	if not rewardUseSkill() then return 0, {} end
	normalizeStealSkillCriteria()
	local record = getPetSkillRecordByName(petName)
	if type(record) ~= "table" or type(record.abilities) ~= "table" then
		return 0, {}
	end
	local score = 0
	local matched = {}
	for _, ability in ipairs(record.abilities) do
		if type(ability) == "table" and ability.hatEffect ~= true then
			local types = abilitySkillTypes(ability)
			for skillName in pairs(types) do
				if stealSkillCriteria[skillName] == true then
					matched[skillName] = true
					local mag = math.max(tonumber(ability.mag) or 0, tonumber(ability.mag2) or 0)
					score += SKILL_BASE_SCORE + (mag * SKILL_EXTRA_SCORE)
				end
			end
		end
	end
	local out = {}
	for skillName in pairs(matched) do out[#out + 1] = skillName end
	table.sort(out)
	return score, out
end

function getAllSkillTypesByPetName(petName)
	local record = getPetSkillRecordByName(petName)
	if type(record) ~= "table" or type(record.abilities) ~= "table" then
		return {}
	end

	local found = {}
	for _, ability in ipairs(record.abilities) do
		if type(ability) == "table" and ability.hatEffect ~= true then
			local types = abilitySkillTypes(ability)
			for skillName in pairs(types) do
				found[skillName] = true
			end
		end
	end

	local out = {}
	for skillName in pairs(found) do out[#out + 1] = skillName end
	table.sort(out)
	return out
end

function parseRewardNumber(v)
	if v == nil then return 0 end
	if type(v) == "number" then return v end

	local text = tostring(v):gsub(",", "")
	local numberText, suffix = text:match("(%-?%d+%.?%d*)%s*([A-Za-z]+)")
	local n = tonumber(numberText or text:match("%-?%d+%.?%d*")) or 0

	local compactMultipliers = {
		k = 1e3,
		m = 1e6,
		b = 1e9,
		t = 1e12,
		qa = 1e15,
		qi = 1e18,
		sx = 1e21,
		sp = 1e24,
		oc = 1e27,
		no = 1e30,
		dc = 1e33,
		ud = 1e36,
		dd = 1e39,
		td = 1e42,
		qad = 1e45,
		qid = 1e48,
		sxd = 1e51,
		spd = 1e54,
		od = 1e57,
		nd = 1e60,
		vg = 1e63,
		uvg = 1e66,
		dvg = 1e69,
		tvg = 1e72,
		qavg = 1e75,
		qivg = 1e78,
		sxvg = 1e81,
		spvg = 1e84,
		ovg = 1e87,
		nvg = 1e90,
		tg = 1e93,
		utg = 1e96,
		dtg = 1e99,
		ttg = 1e102,
		qatg = 1e105,
		qitg = 1e108,
		sxtg = 1e111,
		sptg = 1e114,
		otg = 1e117,
		ntg = 1e120,
	}

	if suffix then
		local mult = compactMultipliers[tostring(suffix):lower()]
		if mult then
			return n * mult
		end
	end

	return n
end

function getDeepRewardNumber(tbl, keys)
	if type(tbl) ~= "table" then return 0 end

	local best = 0
	local function scan(t)
		if type(t) ~= "table" then return end
		for k, v in pairs(t) do
			local key = tostring(k or ""):lower():gsub("[%s_%-]", "")
			if keys[key] then
				best = math.max(best, parseRewardNumber(v))
			end
			if type(v) == "table" then
				scan(v)
			end
		end
	end

	scan(tbl)
	return best
end

function getUiRewardPower(card)
	local level, damage, health = 0, 0, 0
	if not card then return level, damage, health end

	pcall(function()
		for _, d in ipairs(card:GetDescendants()) do
			if d:IsA("TextLabel") or d:IsA("TextButton") then
				local nameBlob = tostring(d.Name or ""):lower() .. " " .. tostring(d.Parent and d.Parent.Name or ""):lower() .. " " .. tostring(d.Parent and d.Parent.Parent and d.Parent.Parent.Name or ""):lower()
				local value = parseRewardNumber(d.Text)

				if nameBlob:find("level") or nameBlob:find("lvl") then
					level = math.max(level, value)
				elseif nameBlob:find("damage") or nameBlob:find("dmg") or nameBlob:find("atk") or nameBlob:find("attack") then
					damage = math.max(damage, value)
				elseif nameBlob:find("health") or nameBlob:find("hp") then
					health = math.max(health, value)
				end
			end
		end
	end)

	return level, damage, health
end

function getRewardCardText(card)
	local parts = {tostring(card and card.Name or "")}
	if card then
		for _, d in ipairs(card:GetDescendants()) do
			if d:IsA("TextLabel") or d:IsA("TextButton") then
				table.insert(parts, tostring(d.Text or ""))
			end
			table.insert(parts, tostring(d.Name or ""))
		end
	end
	return table.concat(parts, " "), normText(table.concat(parts, " "))
end

function getRewardTierFromString(value)
	local blob = normText(value)
	if blob == "" then return "", 0 end

	local bestTier = ""
	local bestWeight = 0
	for tierName, weight in pairs(REWARD_TIER_WEIGHT) do
		if tierName ~= "" and tonumber(weight) and tonumber(weight) > bestWeight then
			if blob:find(normText(tierName), 1, true) then
				bestTier = tierName
				bestWeight = tonumber(weight)
			end
		end
	end

	return bestTier, bestWeight
end

function getRewardTierFromConfig(name, rewardType)
	local itemName = tostring(name or "")
	if itemName == "" then return "", 0 end

	local tierName = ""
	local typ = normText(rewardType)

	pcall(function()
		if (typ == "" or typ:find("pet", 1, true)) and PetConfig and type(PetConfig.getTier) == "function" then
			tierName = PetConfig.getTier(itemName) or tierName
		end
	end)
	if tierName == "" then
		pcall(function()
			if (typ == "" or typ:find("hat", 1, true)) and HatConfig and type(HatConfig.getTier) == "function" then
				tierName = HatConfig.getTier(itemName) or tierName
			end
		end)
	end

	local _, weight = getRewardTierFromString(tierName)
	return tierName, weight
end

function getRewardCardTierWeight(card)
	local best = 0

	local function scan(value)
		local _, weight = getRewardTierFromString(value)
		if weight > best then best = weight end
	end

	if not card then return best end

	pcall(function()
		scan(card.Name)
		for _, attrName in ipairs({"Tier", "tier", "TierName", "tierName", "Rarity", "rarity", "Quality", "quality"}) do
			scan(card:GetAttribute(attrName))
		end

		for _, d in ipairs(card:GetDescendants()) do
			scan(d.Name)
			for _, attrName in ipairs({"Tier", "tier", "TierName", "tierName", "Rarity", "rarity", "Quality", "quality"}) do
				scan(d:GetAttribute(attrName))
			end
			if d:IsA("TextLabel") or d:IsA("TextButton") then
				scan(d.Text)
			end
		end
	end)

	return best
end

function oldRewardScore(card)
	local score = 0
	pcall(function()
		local tierWeight = math.max(1, getRewardCardTierWeight(card))
		local level, damage, health = getUiRewardPower(card)
		score = calcStealRewardScore(tierWeight, level, damage, health)
		local petName = getRewardPetNameFromCard(card)
		local targetMatch = getStealPriorityMatchFromCard(card)
		if targetMatch then
			petName = targetMatch
			score += STEAL_PRIORITY_NAME_SCORE
		else
			score += getStealPriorityNameScore(petName)
		end
		if rewardUseSkill() then
			score += getSkillScoreByPetName(petName)
		end
	end)
	return score
end

function getVisibleRewardCards()
	local victory = getVictoryFrame()
	local frame = victory and victory:FindFirstChild("Frame")
	if not frame or not isVisibleOnScreen(frame) then return {} end

	local cards = {}

	for i = 1, 5 do
		local r = frame:FindFirstChild("Reward_" .. i)
		if r and r:IsA("GuiObject") and isVisibleOnScreen(r) then
			table.insert(cards, {frame = r, index = i, text = select(2, getRewardCardText(r))})
		end
	end

	if #cards > 0 then
		table.sort(cards, function(a, b) return a.index < b.index end)
		return cards
	end

	for _, child in ipairs(frame:GetChildren()) do
		if child:IsA("GuiObject") and child.Visible and child ~= frame:FindFirstChild("Holder") then
			if child.Name:find("Reward") or child.Name:find("Holder") or child:FindFirstChildWhichIsA("GuiButton", true) then
				table.insert(cards, {frame = child, index = #cards + 1, x = child.AbsolutePosition.X, text = select(2, getRewardCardText(child))})
			end
		end
	end

	table.sort(cards, function(a, b) return (a.x or 0) < (b.x or 0) end)
	for i, c in ipairs(cards) do c.index = i end
	return cards
end

function rewardCardProfileText(cardData)

	if type(cardData) ~= "table" then return "" end

	local rawParts = {
		cardData.rewardType,
		cardData.name,
		cardData.title,
		cardData.tierName,
		cardData.tier,
		cardData.chestTier,
		cardData.rarity,
		cardData.quality,
		cardData.lane,
	}

	local parts = {}
	for _, v in ipairs(rawParts) do
		if v ~= nil then
			table.insert(parts, tostring(v))
		end
	end

	return normText(table.concat(parts, " "))
end

function profileMatchScore(profile, cards)
	if type(profile) ~= "table" or type(profile.cards) ~= "table" then return -math.huge end
	if #profile.cards ~= #cards then return -math.huge end

	local score = 0
	for i, ui in ipairs(cards) do
		local cardData = profile.cards[i]
		local ptxt = rewardCardProfileText(cardData)
		local uitxt = ui.text or ""

		if ptxt ~= "" and uitxt ~= "" then
			local name = normText(cardData.name or cardData.title or "")
			local typ = normText(cardData.rewardType or cardData.lane or "")
			local tier = normText(cardData.tierName or "")

			if name ~= "" and uitxt:find(name, 1, true) then score += 5 end
			if typ ~= "" and uitxt:find(typ, 1, true) then score += 3 end
			if typ == "petxp" and (uitxt:find("petxp") or uitxt:find("xp")) then score += 4 end
			if typ == "forgegems" and (uitxt:find("forge") or uitxt:find("gems")) then score += 4 end
			if tier ~= "" and uitxt:find(tier, 1, true) then score += 2 end
		end
	end

	return score
end

function findMatchingRewardProfile(cards)

	local profilesRoot = cachedChestRewardProfiles
	local profiles = profilesRoot and profilesRoot.profiles
	if type(profiles) ~= "table" then
		return nil, "no_cached_profiles"
	end

	local bestProfile = nil
	local bestScore = -math.huge

	for _, profile in ipairs(profiles) do
		local s = profileMatchScore(profile, cards)
		if s > bestScore then
			bestScore = s
			bestProfile = profile
		end
	end

	if bestProfile and bestScore >= 3 then
		return bestProfile, "matched_text_" .. tostring(bestScore)
	end

	local countMatched = {}
	for _, profile in ipairs(profiles) do
		if type(profile.cards) == "table" and #profile.cards == #cards then
			table.insert(countMatched, profile)
		end
	end

	if #countMatched == 1 then
		return countMatched[1], "matched_count_only"
	end

	return nil, "match_low_" .. tostring(bestScore)
end

function getServerRewardTierWeight(cardData)
	if type(cardData) ~= "table" then return 0 end

	local best = 0
	local function scan(value)
		local _, weight = getRewardTierFromString(value)
		if weight > best then best = weight end
	end

	scan(cardData.tierName)
	scan(cardData.tier)
	scan(cardData.chestTier)
	scan(cardData.rarity)
	scan(cardData.quality)

	local numericRank = tonumber(cardData.tierRank or cardData.rarityRank or cardData.rank)
	if numericRank and numericRank > best then
		best = numericRank
	end

	local _, configWeight = getRewardTierFromConfig(cardData.name or cardData.title, cardData.rewardType or cardData.lane)
	if configWeight > best then
		best = configWeight
	end

	scan(rewardCardProfileText(cardData))

	return best
end

function serverRewardScore(cardData)
	if type(cardData) ~= "table" then return 0 end

	local tierWeight = getServerRewardTierWeight(cardData)

	local level = getDeepRewardNumber(cardData, {
		level = true,
		lvl = true,
	})
	local damage = getDeepRewardNumber(cardData, {
		damage = true,
		dmg = true,
		atk = true,
		attack = true,
		power = true,
	})
	local health = getDeepRewardNumber(cardData, {
		health = true,
		hp = true,
		life = true,
	})

	local score = calcStealRewardScore(tierWeight, level, damage, health)
	local petName = cardData.name or cardData.title
	local targetMatch = getStealPriorityMatchFromProfileCard(cardData)
	if targetMatch then
		petName = targetMatch
		score += STEAL_PRIORITY_NAME_SCORE
	else
		score += getStealPriorityNameScore(petName)
	end
	if rewardUseSkill() then
		score += getSkillScoreByPetName(petName)
	end
	return score
end

function getRewardClickTarget(cardFrame)
	if not cardFrame then return nil, "no_card" end

	local exact = cardFrame:FindFirstChild("_ClickZone")
	if exact and exact:IsA("GuiButton") and isVisibleOnScreen(exact) then
		return exact, "exact__ClickZone"
	end

	local deep = cardFrame:FindFirstChild("_ClickZone", true)
	if deep and deep:IsA("GuiButton") and isVisibleOnScreen(deep) then
		return deep, "deep__ClickZone"
	end

	for _, obj in ipairs(cardFrame:GetDescendants()) do
		if obj:IsA("GuiButton") and isVisibleOnScreen(obj) then
			local n = tostring(obj.Name):lower()
			if n:find("click") or n:find("button") or n:find("select") or n:find("reward") then
				return obj, "named_button_" .. obj.Name
			end
		end
	end

	local anyBtn = cardFrame:FindFirstChildWhichIsA("GuiButton", true)
	if anyBtn and isVisibleOnScreen(anyBtn) then
		return anyBtn, "any_guibutton_" .. anyBtn.Name
	end

	if cardFrame:IsA("GuiButton") and isVisibleOnScreen(cardFrame) then
		return cardFrame, "card_is_button"
	end

	if cardFrame:IsA("GuiObject") and isVisibleOnScreen(cardFrame) then
		return cardFrame, "card_frame_fallback"
	end

	return nil, "no_visible_target"
end

function clickRewardByOldUIScore(cards, reason)
	if type(cards) ~= "table" or #cards == 0 then return false end
	table.sort(cards, function(a, b)

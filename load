			current = tonumber(current)
			max = tonumber(max)

			if current and max and current >= max then
				inventoryFull = true
			end
		end
	end)

	local display = nil
	if inventoryText and inventoryText ~= "" then
		if inventoryFull then
			display = inventoryText

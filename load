function getKnownHatEffectValues(data, hatId)
	hatId = tostring(hatId)

	local damageValue = 0
	local hpValue = 0
	local generalValue = 0
	local textParts = {}

	if type(data) ~= "table" or type(data.petDetails) ~= "table" then
		return damageValue, hpValue, generalValue, textParts
	end

	for _, detail in pairs(data.petDetails) do
		if type(detail) == "table" and type(detail.equippedHat) == "table" then
			local equippedHatId = tostring(detail.equippedHat.id or detail.equippedHat.hatId or "")
			if equippedHatId == hatId and type(detail.abilities) == "table" then
				for _, ability in ipairs(detail.abilities) do
					if type(ability) == "table" and ability.hatEffect == true then
						local effect = tostring(ability.effect or ""):lower()
						local target = tostring(ability.target or ""):lower()
						local label = tostring(ability.label or ""):lower()
						local mag = tonumber(ability.mag) or 0
						local mag2 = tonumber(ability.mag2) or 0

						table.insert(textParts, label)
						table.insert(textParts, effect)
						table.insert(textParts, target)

						if effect:find("damage") or effect:find("buffatk") or effect:find("attack") or effect:find("splash") then
							damageValue += mag + mag2
						elseif effect:find("heal") or effect:find("hp") or effect:find("defense") or effect:find("shield") then
							hpValue += mag + mag2
						else
							generalValue += mag + mag2
						end

						if target:find("all") or target:find("friend") or target:find("enemy") then
							generalValue += 2
						end
					end
				end
			end
		end
	end

	return damageValue, hpValue, generalValue, textParts
end

function getHatInfoForEquip(data, hatId)
	hatId = tostring(hatId)

	local hats = getHatSources(data) or {}
	local hatDetails = getHatDetailsSource(data) or {}

	local basic = hats[hatId]
	local details = hatDetails[hatId]

	local mergedNumbers = {}
	local textParts = {hatId:lower()}

	if type(basic) == "table" then
		scanNumbersDeep(basic, mergedNumbers)
		scanTextDeep(basic, textParts)
	end

	if type(details) == "table" then
		scanNumbersDeep(details, mergedNumbers)
		scanTextDeep(details, textParts)
	end

	local tierName = "Common"
	local tierRank = 0
	local level = 0

	if type(details) == "table" then
		tierName = details.tierName or details.tier or tierName
		tierRank = tonumber(details.tierRank) or tierRank
		level = tonumber(details.level) or level
	end

	if type(basic) == "table" then
		tierName = basic.tierName or basic.tier or tierName
		tierRank = tonumber(basic.tierRank) or tierRank
		level = math.max(level, tonumber(basic.level) or 0)
	end

	local damageValue = 0
	local hpValue = 0
	local generalValue = 0

	for key, value in pairs(mergedNumbers) do
		local simpleKey = key:match("[^.]+$") or key

		if DAMAGE_KEYS[simpleKey] then
			damageValue += value
		elseif HP_KEYS[simpleKey] then
			hpValue += value
		elseif GENERAL_KEYS[simpleKey] then
			generalValue += value
		else
			generalValue += value * 0.25
		end
	end

	local knownDmg, knownHp, knownGeneral, knownText = getKnownHatEffectValues(data, hatId)
	damageValue += knownDmg
	hpValue += knownHp
	generalValue += knownGeneral
	for _, part in ipairs(knownText) do
		table.insert(textParts, part)
	end

	local textBlob = table.concat(textParts, " ")

	if textBlob:find("damage") or textBlob:find("attack") or textBlob:find("atk") or textBlob:find("crit") or textBlob:find("power") or textBlob:find("bolt") then
		damageValue += 50
	end

	if textBlob:find("hp") or textBlob:find("health") or textBlob:find("defense") or textBlob:find("defence") or textBlob:find("shield") or textBlob:find("armor") or textBlob:find("heal") or textBlob:find("food") then
		hpValue += 50
	end

	if textBlob:find("boost") or textBlob:find("multiplier") or textBlob:find("bonus") or textBlob:find("luck") or textBlob:find("friend") then
		generalValue += 50
	end

	local baseScore = getTierBase(tierName, tierRank)
		+ (level * 150)
		+ (damageValue * 3000)
		+ (hpValue * 1800)
		+ (generalValue * 2200)

	local hatType = "general"
	if damageValue > hpValue and damageValue >= generalValue * 0.7 then
		hatType = "damage"
	elseif hpValue > damageValue and hpValue >= generalValue * 0.7 then
		hatType = "tank"
	end

	return {
		hatId = hatId,
		tierName = tierName,
		tierRank = tierRank,
		level = level,
		damageValue = damageValue,
		hpValue = hpValue,
		generalValue = generalValue,
		baseScore = baseScore,
		hatType = hatType,
	}
end

function collectBestPetsForEquip(data)
	local list = {}

	if type(data) ~= "table" or type(data.pets) ~= "table" then
		return list
	end

	for petId in pairs(data.pets) do
		table.insert(list, getPetInfoForEquip(data, petId))
	end

	table.sort(list, function(a, b)
		return a.baseScore > b.baseScore
	end)

	local best = {}
	for i = 1, math.min(5, #list) do
		best[i] = list[i]
	end

	return best
end

function collectHatsForEquip(data)
	local source = getHatSources(data)
	local list = {}

	if type(source) ~= "table" then
		return list
	end

	for hatId in pairs(source) do
		table.insert(list, getHatInfoForEquip(data, hatId))
	end

	table.sort(list, function(a, b)
		return a.baseScore > b.baseScore
	end)

	return list
end

function petHatFitScore(pet, hat)
	if not hat then return 0 end

	local fit = hat.baseScore

	fit += hat.damageValue * math.max(1, pet.atk) * 120
	fit += hat.hpValue * math.max(1, pet.hp) * 70
	fit += hat.generalValue * math.max(1, pet.baseScore / 100000) * 5000

	if pet.role == "damage" and hat.hatType == "damage" then
		fit *= 1.25
	elseif pet.role == "tank" and hat.hatType == "tank" then
		fit *= 1.20
	elseif hat.hatType == "general" then
		fit *= 1.08
	end

	return fit
end

function assignBestHatsToPets(bestPets, hats)
	local usedHats = {}
	local result = {}

	for i, pet in ipairs(bestPets) do
		result[i] = {
			pet = pet,
			hat = nil,
			fitScore = 0,
		}
	end

	while true do
		local bestSlot = nil
		local bestHatIndex = nil
		local bestFit = -math.huge

		for slotIndex, entry in ipairs(result) do
			if not entry.hat then
				for hatIndex, hat in ipairs(hats) do
					if not usedHats[hat.hatId] then
						local fit = petHatFitScore(entry.pet, hat)
						if fit > bestFit then
							bestFit = fit
							bestSlot = slotIndex
							bestHatIndex = hatIndex
						end
					end
				end
			end
		end

		if not bestSlot or not bestHatIndex then
			break
		end

		local chosenHat = hats[bestHatIndex]
		result[bestSlot].hat = chosenHat
		result[bestSlot].fitScore = bestFit
		usedHats[chosenHat.hatId] = true
	end

	return result
end

function makeSmartEquipPayload(data)
	local bestPets = collectBestPetsForEquip(data)
	if #bestPets <= 0 then
		return nil
	end

	local hats = collectHatsForEquip(data)
	local assignments = assignBestHatsToPets(bestPets, hats)

	local payload = {
		slots = {}
	}

	for i, entry in ipairs(assignments) do
		payload.slots[i] = {
			petId = entry.pet.petId
		}

		if entry.hat then
			payload.slots[i].hatId = entry.hat.hatId
		end
	end

	return payload
end


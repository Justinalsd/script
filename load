function EtherHubCore.GetAutoRunSource()
    local coreUrl = tostring(getgenv().EtherHubCoreUrl or ETHERHUB_CORE_URL or "")
    local uiUrl = tostring(getgenv().EtherHubUIUrl or ETHERHUB_UI_URL or "")
    local skillUrl = tostring(getgenv().EtherHubPetSkillUrl or ETHERHUB_PET_SKILL_URL or "")
    if coreUrl == "" or coreUrl == "PUT_CORE_RAW_URL_HERE" then
        return nil, "core_url_not_set"
    end
    local lines = {}
    lines[#lines + 1] = "getgenv().EtherHubAutoReconnect = true"
    lines[#lines + 1] = "getgenv().EtherHubAutoRunOnTeleport = true"
    if uiUrl ~= "" and uiUrl ~= "PUT_UI_RAW_URL_HERE" then
        lines[#lines + 1] = "getgenv().EtherHubUIUrl = " .. string.format("%q", uiUrl)
    end
    if skillUrl ~= "" and skillUrl ~= "PUT_PET_SKILL_RAW_URL_HERE" then
        lines[#lines + 1] = "getgenv().EtherHubPetSkillUrl = " .. string.format("%q", skillUrl)
    end
    lines[#lines + 1] = "getgenv().EtherHubCoreUrl = " .. string.format("%q", coreUrl)
    lines[#lines + 1] = "loadstring(game:HttpGet(getgenv().EtherHubCoreUrl))()"
    return table.concat(lines, "\n"), "ok"
end

function EtherHubCore.QueueAutoRun()
    if AUTO_RUN_ON_TELEPORT_ENABLED ~= true then return false, "auto_run_disabled" end
    local queueFn = EtherHubCore.GetQueueOnTeleport()
    if not queueFn then return false, "queue_on_teleport_missing" end
    local source, reason = EtherHubCore.GetAutoRunSource()
    if not source then return false, reason end
    local ok, err = pcall(queueFn, source)
    return ok == true, ok and "queued" or tostring(err or "queue_failed")
end

function EtherHubCore.Reconnect(reason)
    if AUTO_RECONNECT_ENABLED ~= true then return false, "auto_reconnect_disabled" end
    EtherHubCore.QueueAutoRun()
    setStatus("Reconnecting...", Color3.fromRGB(255, 170, 0))
    local placeId = game.PlaceId
    local jobId = tostring(game.JobId or "")
    if jobId ~= "" then
        local ok = pcall(function()
            TeleportService:TeleportToPlaceInstance(placeId, jobId, player)
        end)
        if ok then return true, "reconnect_same_server" end
    end
    local ok = pcall(function()
        TeleportService:Teleport(placeId, player)
    end)
    return ok == true, ok and "reconnect_place" or "teleport_failed"
end

function EtherHubCore.StartAutoReconnect()
    if EtherHubCore.AutoReconnectStarted then return true end
    EtherHubCore.AutoReconnectStarted = true
    pcall(function()
        TeleportService.TeleportInitFailed:Connect(function(targetPlayer)
            if targetPlayer == player then
                task.delay(getgenv().EtherHubReconnectDelay or 3, function()
                    EtherHubCore.Reconnect("teleport_failed")
                end)
            end
        end)
    end)
    task.spawn(function()
        local lastReconnectAt = 0
        while true do
            task.wait(2)
            if AUTO_RECONNECT_ENABLED == true then
                local promptGui = CoreGui:FindFirstChild("RobloxPromptGui")
                local overlay = promptGui and promptGui:FindFirstChild("promptOverlay")
                local errorPrompt = overlay and overlay:FindFirstChild("ErrorPrompt")
                if errorPrompt and errorPrompt.Visible == true and tick() - lastReconnectAt > 10 then
                    lastReconnectAt = tick()
                    task.wait(getgenv().EtherHubReconnectDelay or 3)
                    EtherHubCore.Reconnect("error_prompt")
                end
            end
        end
    end)
    return true
end

function EtherHubCore.RejoinOnPrepareTimeout(reason)
    if REJOIN_ON_PREPARE_TIMEOUT ~= true then return false, "prepare_timeout_rejoin_disabled" end
    if tick() - lastPrepareTimeoutRejoinAt < PREPARE_TIMEOUT_REJOIN_COOLDOWN then return false, "prepare_timeout_rejoin_cooldown" end
    lastPrepareTimeoutRejoinAt = tick()
    task.spawn(function()
        setStatus("Prepare timeout. Rejoining...", Color3.fromRGB(255, 170, 0))
        task.wait(1.5)
        EtherHubCore.Reconnect(reason or "prepare_timeout")
    end)
    return true, "prepare_timeout_rejoin_started"
end

function EtherHubCore.LoadUI(force)
    if force ~= true and EtherHubCore.UILoaded == true then return true, "ui_already_loaded" end
    local uiUrl = tostring(getgenv().EtherHubUIUrl or ETHERHUB_UI_URL or "")
    if uiUrl == "" or uiUrl == "PUT_UI_RAW_URL_HERE" then
        setStatus("UI URL not set", Color3.fromRGB(255, 170, 0))
        return false, "ui_url_not_set"
    end
    local okGet, source = pcall(function()
        return game:HttpGet(uiUrl)
    end)
    if not okGet or type(source) ~= "string" or source == "" then
        setStatus("UI load failed", Color3.fromRGB(255, 80, 80))
        return false, "ui_download_failed"
    end
    local fn, compileErr = loadstring(source)
    if type(fn) ~= "function" then
        setStatus("UI compile failed", Color3.fromRGB(255, 80, 80))
        return false, compileErr or "ui_compile_failed"
    end
    local okRun, runErr = pcall(fn)
    if not okRun then
        setStatus("UI run failed", Color3.fromRGB(255, 80, 80))
        return false, runErr or "ui_run_failed"
    end
    EtherHubCore.UILoaded = true
    setStatus("UI loaded", Color3.fromRGB(0, 255, 150))
    return true, "ui_loaded"
end



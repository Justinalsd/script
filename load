function getMatchSpeedButtonText(obj)
	if not obj then return "" end

	local parts = {}
	local function addText(v)
		v = tostring(v or "")
		if v ~= "" then
			parts[#parts + 1] = v
		end
	end

	pcall(function()
		addText(obj.Name)
		addText(obj.Text)
		addText(obj:GetAttribute("MatchSpeed"))
		addText(obj:GetAttribute("Speed"))
		addText(obj:GetAttribute("Value"))
	end)

	for _, child in ipairs(obj:GetDescendants()) do
		pcall(function()
			addText(child.Name)
			if child:IsA("TextLabel") or child:IsA("TextButton") or child:IsA("TextBox") then
				addText(child.Text)
			end
			addText(child:GetAttribute("MatchSpeed"))
			addText(child:GetAttribute("Speed"))
			addText(child:GetAttribute("Value"))
		end)
	end

	return table.concat(parts, " "):lower()
end

function isMatchSpeed2xTarget(obj)
	local text = getMatchSpeedButtonText(obj):gsub("%s+", "")
	if text == "" then
		return false, "matchspeed_target_unknown"
	end

	if text:find("1x", 1, true) or text:find("x1", 1, true) or text:find("speed1", 1, true) or text:find("matchspeed1", 1, true) then
		return false, "matchspeed_target_is_1x"
	end

	if text:find("2x", 1, true) or text:find("x2", 1, true) or text:find("speed2", 1, true) or text:find("matchspeed2", 1, true) then
		return true, "matchspeed_target_is_2x"
	end

	return false, "matchspeed_target_not_confirmed_2x"
end

function getMatchSpeedOptionText(obj)

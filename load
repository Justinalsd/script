function sendBattleWebhook(data)
	if webhookUrl == "" then
		return
	end

	local color = data.Outcome == "Won Battle"
		and 65280
		or 16711680

	local fields = {}

	if data.Outcome == "Won Battle" and data.Pet then
		local petInfo = string.format(
			"%s\nLevel: %s\nDamage: %s\nHealth: %s",
			tostring(data.Pet.Name),
			tostring(data.Pet.Level),
			tostring(data.Pet.Damage),
			tostring(data.Pet.Health)
		)

		if data.Pet.Tier and tostring(data.Pet.Tier) ~= "" then
			petInfo ..= "\nTier: " .. tostring(data.Pet.Tier)
		end

		if data.Pet.RewardType and tostring(data.Pet.RewardType) ~= "" then
			petInfo ..= "\nReward Type: " .. tostring(data.Pet.RewardType)
		end

		if data.Pet.ProfileSource and tostring(data.Pet.ProfileSource) ~= "" then
			petInfo ..= "\nReward Source: " .. tostring(data.Pet.ProfileSource)
		end

		if data.Pet.TargetMatched or data.Pet.PriorityMatched then
			petInfo ..= "\nTarget Name: Yes"
		end

		if data.Pet.SellLocked then
			petInfo ..= "\nProtected From Sell: Yes"
		end

		if type(data.Pet.AllSkills) == "table" and #data.Pet.AllSkills > 0 then
			petInfo ..= "\nSkills: " .. table.concat(data.Pet.AllSkills, ", ")
		elseif type(data.Pet.SkillMatches) == "table" and #data.Pet.SkillMatches > 0 then
			petInfo ..= "\nSkills: " .. table.concat(data.Pet.SkillMatches, ", ")
		end

		table.insert(fields, {
			name = "🐶 Pet Stolen 🐶",
			value = petInfo,
			inline = false
		})
	end

	table.insert(fields, {
		name = "🧪 XP Gained",
		value = tostring(data.XPGained or "0"),
		inline = true
	})

	table.insert(fields, {
		name = "🧪 Session XP",
		value = tostring(data.SessionXP or "0"),
		inline = true
	})

	table.insert(fields, {
		name = "⚔️ Session Battles",
		value = tostring(data.Battles or 0),
		inline = true
	})

	table.insert(fields, {
		name = "⏰ Session Runtime",
		value = formatSessionRuntime(),
		inline = true
	})

	table.insert(fields, {
		name = "🏆 Wins",
		value = tostring(sessionWins),
		inline = true
	})

	table.insert(fields, {
		name = "😔 Losses",
		value = tostring(sessionLosses),
		inline = true
	})

	local winRate = 0

	if data.Battles and data.Battles > 0 then
		winRate = (data.Wins / data.Battles) * 100
	end

	table.insert(fields, {
		name = "🏆 Win Rate",
		value = string.format("%.1f%%", winRate),
		inline = true
	})

	if data.Outcome == "Won Battle" and data.Chest ~= "No Chest Won" then
		table.insert(fields, {
			name = "🎁 Chest Won",
			value = tostring(data.Chest),
			inline = false
		})
	end

	local chestOrder = {
		"Basic Chest",
		"Forest Chest",
		"Noble Chest",
		"Hero Chest",
		"Desert Chest",
		"Rare Chest",
		"Beach Chest",
		"Frozen Chest",
		"Castle Chest",
		"Castle/Boss Chest",
		"Savannah Chest",
		"Epic Chest",
		"Boss Chest",
		"Mythic Chest",
	}

	local chestText = ""
	local totalChests = 0
	local usedChests = {}

	for _, chestName in ipairs(chestOrder) do
		local amount = tonumber(sessionChestCounts[chestName]) or 0
		if amount > 0 then
			usedChests[chestName] = true
			totalChests += amount
			chestText ..= chestName .. ": " .. amount .. "\n"
		end
	end

	for chestName, amount in pairs(sessionChestCounts) do
		if not usedChests[chestName] and tonumber(amount) and tonumber(amount) > 0 then
			totalChests += tonumber(amount)
			chestText ..= tostring(chestName) .. ": " .. tostring(amount) .. "\n"
		end
	end

	if chestText ~= "" then
		chestText ..= "\nTotal: " .. tostring(totalChests)
	end

	table.insert(fields, {
		name = "🎁 Session Chests",
		value = chestText ~= "" and chestText or "None Yet",
		inline = false
	})

	local embed = {
		title = data.Outcome == "Won Battle"
			and "🏆 Battle Victory"
			or "💀 Battle Defeat",
		color = color,
		fields = fields,
		timestamp = DateTime.now():ToIsoDate()
	}

	local descriptionLines = {}

	if data.Pet and data.Pet.Inventory then
		table.insert(descriptionLines, "📦 **Inventory:** " .. tostring(data.Pet.Inventory))
	end

	if data.Pet and data.Pet.InventoryFull then
		table.insert(descriptionLines, "⚠️ **Inventory is full, pet auto sold!**")
	end

	if #descriptionLines > 0 then
		embed.description = table.concat(descriptionLines, "\n")
	end

	if data.Pet and data.Pet.ImageId then
		local assetId = tostring(data.Pet.ImageId):match("%d+")

		if assetId then
			local success, response = pcall(function()
				return HttpService:JSONDecode(
					game:HttpGet(
						"https://thumbnails.roblox.com/v1/assets?assetIds="
							.. assetId ..
							"&size=420x420&format=Png&isCircular=false"
					)
				)
			end)

			if success
				and response
				and response.data
				and response.data[1]
				and response.data[1].imageUrl then

				embed.thumbnail = {
					url = response.data[1].imageUrl
				}
			end
		end
	end

	local body = {
		content = (
			data.Outcome == "Won Battle"
				and discordUserId ~= ""
				and "<@" .. discordUserId .. ">"
			or nil
		),
		embeds = {
			embed
		}
	}

	sendWebhookRequest({
		Url = webhookUrl,
		Method = "POST",
		Headers = {
			["Content-Type"] = "application/json"
		},
		Body = HttpService:JSONEncode(body)
	})
end


	if not autoFarmEnabled then return true end
	if clickVictorySteal() then
		task.wait(2.5)
		if not autoFarmEnabled then return true end
		runCleanSystem(false)
		nextPlayAllowedAt = tick() + AFTER_BATTLE_PLAY_DELAY
		return true
	end

	return false
end


function formatGameNumber(n)
	n = tonumber(n) or 0

	if math.abs(n) < 1000 then
		return tostring(math.floor(n + 0.0000001))
	end

	for _, info in ipairs(COMPACT_SUFFIXES) do
		local divisor = info[1]
		local suffix = info[2]

		if math.abs(n) >= divisor then
			local scaled = math.floor((n / divisor) * 10 + 0.5) / 10
			local txt = string.format("%.1f", scaled)
				:gsub("%.0+$", "")
				:gsub("(%..-)0+$", "%1")
				:gsub("%.$", "")

			return txt .. suffix
		end
	end

	return tostring(math.floor(n + 0.0000001))
end

function parseGameNumber(text)
	text = tostring(text or "")
	text = text:gsub(",", "")
	text = text:gsub("%+", "")
	text = text:gsub("%s+", "")

	local value, suffix = text:match("([%d%.]+)([%a]+)")

	if value then
		value = tonumber(value)

		local multipliers = {
			k = 1e3,
			m = 1e6,
			b = 1e9,
			t = 1e12,
			qa = 1e15,
			qi = 1e18,
			sx = 1e21,
			sp = 1e24,
			oc = 1e27,
			no = 1e30,
			dc = 1e33,
		}

		local mult = multipliers[string.lower(suffix)]

		if mult then
			return value * mult
		end
	end

	return tonumber(text:match("[%d%.]+")) or 0
end

function formatSessionRuntime()
	local elapsed = math.floor(tick() - sessionStartTime)

	local hours = math.floor(elapsed / 3600)
	local minutes = math.floor((elapsed % 3600) / 60)
	local seconds = elapsed % 60

	if hours > 0 then
		return string.format("%dh %dm %ds", hours, minutes, seconds)
	elseif minutes > 0 then
		return string.format("%dm %ds", minutes, seconds)
	else
		return string.format("%ds", seconds)
	end
end


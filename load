function rewardHideEtherHubUI()
	local oldStates = {}
	local targets = {
		ScreenGui,
		Main,
		FloatBtn,
		playerGui:FindFirstChild("EtherHubAutoFarmFixed"),
		CoreGui:FindFirstChild("EtherHubAutoFarmFixed"),

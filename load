			petId = tostring(petId)
			local detail = data.petDetails[petId]
			if type(detail) == "table" then
				local cost = tonumber(detail.levelUpCost) or math.huge
				if cost > 0 and cost <= petXp then
					local s = getPetScore(data, petId)

					if s > bestScore or (s == bestScore and cost < bestCost) then
						bestId = petId
						bestCost = cost
						bestScore = s
					end
				end
			end
		end

		if not bestId then
			if didLevel then
				setStatus("No affordable level up", Color3.fromRGB(255, 170, 0))
			end
			return didLevel
		end

		setStatus("Leveling " .. bestId .. " | XP " .. tostring(petXp) .. " / cost " .. tostring(bestCost), Color3.fromRGB(100, 200, 255))
		local ok, result = invokeRemote(R_LevelUpPet, bestId)
		if ok and result ~= false then
			didLevel = true
			task.wait(0.25)
			local freshData = getPlayerData("all")
			if type(prunePetNameLevelLocks) == "function" then
				prunePetNameLevelLocks(freshData, true)
			end
		else
			warn("[EtherHub] LevelUpPet failed:", bestId, result)
			return didLevel
		end
	end

	return didLevel
end

function hasMatchSpeed2x(data)
	if type(data) ~= "table" then return false end

	local direct = data.matchSpeedAllowed == true
		or data.matchSpeed2x == true
		or data.hasMatchSpeed2x == true
		or (type(data.passBenefits) == "table" and (
			data.passBenefits.MatchSpeed2x == true
			or data.passBenefits.MatchSpeed == true
			or data.passBenefits.matchSpeed2x == true
			))
		or (type(data.gamepasses) == "table" and (
			data.gamepasses.MatchSpeed2x == true
			or data.gamepasses.MatchSpeed == true
			or data.gamepasses.matchSpeed2x == true
			))

	if direct then return true end

	local visited = {}
	local function scan(tbl)
		if type(tbl) ~= "table" or visited[tbl] then return false end
		visited[tbl] = true

		for k, v in pairs(tbl) do
			local key = tostring(k or ""):lower():gsub("[%s_%-%./]", "")
			if key:find("matchspeed", 1, true) or key:find("speed2x", 1, true) or key:find("2xspeed", 1, true) then
				if v == true then return true end
				if type(v) == "number" and v >= 2 then return true end
				if type(v) == "string" then
					local text = v:lower()
					if text == "true" or text == "2" or text:find("owned", 1, true) or text:find("unlocked", 1, true) then
						return true
					end
				end
			end

			if type(v) == "table" and scan(v) then
				return true
			end
		end

		return false
	end

	return scan(data)
end


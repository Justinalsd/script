function getPetInfoForEquip(data, petId)
	petId = tostring(petId)

	local basic = data and data.pets and data.pets[petId]
	local details = data and data.petDetails and data.petDetails[petId]

	local tierName = "Common"
	local tierRank = 0
	local score = 0
	local level = 0
	local atk = 0
	local hp = 0
	local sellXp = 0

	local baseAtk = 0
	local baseHp = 0

	if type(details) == "table" then
		tierName = details.tierName or details.tier or tierName
		tierRank = tonumber(details.tierRank) or tierRank
		score = tonumber(details.score) or score
		level = tonumber(details.level) or level

		baseAtk = tonumber(details.baseAtk or details.rawAtk or details.baseDamage) or 0
		baseHp  = tonumber(details.baseHp or details.rawHp or details.baseHealth) or 0
		atk = baseAtk > 0 and baseAtk or (tonumber(details.atk or details.attack or details.damage) or atk)
		hp  = baseHp  > 0 and baseHp  or (tonumber(details.hp or details.health) or hp)
		sellXp = tonumber(details.sellXpValue or details.sellXpCap) or sellXp
	end

	if type(basic) == "table" then
		tierName = basic.tierName or basic.tier or tierName
		tierRank = tonumber(basic.tierRank) or tierRank
		level = math.max(level, tonumber(basic.level) or 0)
		if atk <= 0 then atk = tonumber(basic.atk or basic.attack or basic.damage) or 0 end
		if hp <= 0 then hp = tonumber(basic.hp or basic.health) or 0 end
		sellXp = math.max(sellXp, tonumber(basic.sellXpValue or basic.sellXpCap) or 0)
	end

	local combatScore = (atk or 0) + (hp or 0)
	if combatScore <= 0 then
		combatScore = tonumber(score) or 0
	end

	local abilityBonus = 0
	if type(details) == "table" and type(details.abilities) == "table" then
		for _, ability in ipairs(details.abilities) do
			if type(ability) == "table" and ability.hatEffect ~= true then
				local effect = tostring(ability.effect or ""):lower()
				local target = tostring(ability.target or ""):lower()
				local trigger = tostring(ability.trigger or ""):lower()
				local mag = tonumber(ability.mag) or 0
				local mag2 = tonumber(ability.mag2) or 0

				if effect:find("damage") or effect:find("buffatk") or effect:find("attack") or effect:find("splash") or effect:find("steal") then
					abilityBonus += mag * 10
				elseif effect:find("heal") or effect:find("shield") or effect:find("hp") or effect:find("buff_both") then
					abilityBonus += (mag + mag2) * 7
				elseif effect:find("summon") or effect:find("freeze") or effect:find("stun") or effect:find("debuff") then
					abilityBonus += mag * 8
				else
					abilityBonus += mag * 3
				end

				if target:find("all") then
					abilityBonus += 12
				end
				if trigger:find("start") or trigger:find("round") or trigger:find("attack") or trigger:find("death") or trigger:find("kill") then
					abilityBonus += 4
				end
			end
		end
	end

	local baseScore = (combatScore * 100000)
		+ (abilityBonus * 12000)
		+ (level * 2500)
		+ ((atk or 0) * 800)
		+ ((hp or 0) * 500)
		+ ((tonumber(tierRank) or 0) * 5000)
		+ (sellXp * 0.01)

	local role = "balanced"
	if atk >= hp * 0.55 then
		role = "damage"
	elseif hp >= atk * 1.8 then
		role = "tank"
	end

	return {
		petId = petId,
		tierName = tierName,
		tierRank = tierRank,
		score = score,
		level = level,
		atk = atk,
		hp = hp,
		baseScore = baseScore,
		role = role,
	}
end

function getHatSources(data)

	if not autoFarmEnabled then return false end

	local victory = getVictoryFrame()
	if not victory or not isVisibleOnScreen(victory) then return false end
	if tick() - lastVictoryAction < 2 then return true end
	lastVictoryAction = tick()

	if autoSelectBestEnabled then
		local rewardOk, rewardMode = selectBestRewardUI()
		if not autoFarmEnabled then return true end

		if rewardMode == "direct_claimed" then
			task.wait(2.5)
			if not autoFarmEnabled then return true end
			runCleanSystem(false)
			nextPlayAllowedAt = tick() + AFTER_BATTLE_PLAY_DELAY
			return true
		end
		task.wait(0.6)
		if not autoFarmEnabled then return true end

function normalizeStealCriteria()
	if type(stealUseTier) ~= "boolean" then stealUseTier = STEAL_CRITERIA_DEFAULTS.Tier end
	if type(stealUseLevel) ~= "boolean" then stealUseLevel = STEAL_CRITERIA_DEFAULTS.Level end
	if type(stealUseDamage) ~= "boolean" then stealUseDamage = STEAL_CRITERIA_DEFAULTS.Damage end
	if type(stealUseHealth) ~= "boolean" then stealUseHealth = STEAL_CRITERIA_DEFAULTS.Health end
	if type(stealUseSkill) ~= "boolean" then stealUseSkill = STEAL_CRITERIA_DEFAULTS.Skill end
end

function syncStealCriteriaGlobals()
	normalizeStealCriteria()
	getgenv().EtherHubStealUseTier = stealUseTier
	getgenv().EtherHubStealUseLevel = stealUseLevel
	getgenv().EtherHubStealUseDamage = stealUseDamage
	getgenv().EtherHubStealUseHealth = stealUseHealth
	getgenv().EtherHubStealUseSkill = stealUseSkill
end

syncStealCriteriaGlobals()

function setStealCriterion(name, value)
	local enabled = value == true
	local key = tostring(name or ""):lower()

	if key == "tier" then
		stealUseTier = enabled
	elseif key == "level" then
		stealUseLevel = enabled
	elseif key == "damage" or key == "dmg" then
		stealUseDamage = enabled
	elseif key == "health" or key == "hp" then
		stealUseHealth = enabled
	elseif key == "skill" or key == "skills" or key == "ability" or key == "abilities" then
		stealUseSkill = enabled
	end


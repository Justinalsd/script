function getStealPriorityMatchFromText(text)
	if not hasStealPriorityTargets() then
		return nil
	end

	local raw = tostring(text or "")
	local blob = normalizePetName(raw)
	if blob == "" then
		return nil
	end

	for normalized in pairs(stealPriorityPets) do
		local target = normalizePetName(normalized)
		if target ~= "" and (blob == target or blob:find(target, 1, true)) then
			return resolvePetName(target) or target
		end
	end

	return nil
end

function getStealPriorityMatchFromCard(card)
	if not card then return nil end
	local raw, blob = getRewardCardText(card)
	return getStealPriorityMatchFromText(raw or blob or "")
end

function getStealPriorityMatchFromProfileCard(cardData)
	if type(cardData) ~= "table" then return nil end

	local directName = nil
	if type(getRewardProfilePetName) == "function" then
		directName = getRewardProfilePetName(cardData)
	else
		directName = cardData.name or cardData.title or cardData.displayName or cardData.petName or cardData.PetName or cardData.id or cardData.petId
	end

	if directName and isPriorityPet(directName) then
		return resolvePetName(directName) or tostring(directName)
	end

	local text = ""
	if type(rewardCardProfileText) == "function" then
		text = rewardCardProfileText(cardData)
	else
		local parts = {}
		for _, key in ipairs({"rewardType", "name", "title", "displayName", "petName", "PetName", "id", "petId", "tierName", "tier", "rarity", "quality", "lane"}) do
			if cardData[key] ~= nil then parts[#parts + 1] = tostring(cardData[key]) end
		end
		text = table.concat(parts, " ")
	end

	return getStealPriorityMatchFromText(text)
end

function getStealPriorityMatchFromEntry(entry, profile)
	if type(entry) ~= "table" then return nil end

	local cardData = nil
	if type(profile) == "table" and type(profile.cards) == "table" then
		cardData = profile.cards[entry.index]
	end

	local fromProfile = getStealPriorityMatchFromProfileCard(cardData)
	if fromProfile then return fromProfile end

	local fromCard = getStealPriorityMatchFromCard(entry.frame)
	if fromCard then return fromCard end

	return nil
end

function getStealPriorityNameScore(petName)
	if petName and isPriorityPet(petName) then
		return STEAL_PRIORITY_NAME_SCORE
	end
	local matched = getStealPriorityMatchFromText(petName)
	if matched then
		return STEAL_PRIORITY_NAME_SCORE
	end
	return 0
end


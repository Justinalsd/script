		local handledVictory = false
		pcall(function()
			handledVictory = handleVictory()
		end)
		if not autoFarmEnabled then
			continue
		end
		if handledVictory then
			task.wait(0.2)
			continue
		end

		local handledClaimSkip = false
		pcall(function()
			handledClaimSkip = handleClaimSkip()
		end)
		if not autoFarmEnabled then
			continue
		end
		if handledClaimSkip then
			task.wait(0.08)
			continue
		end

		if isResultScreenVisible() then
			local reveal = game:GetService("Players")
				.LocalPlayer
				.PlayerGui
				.Round
				.Result
				:FindFirstChild("Reveal")

			if reveal and reveal.Visible and not lastRevealProcessed then

				local title = reveal:FindFirstChild("Title")
				local rewards = reveal:FindFirstChild("Rewards")
				local petXp = rewards and rewards:FindFirstChild("PetXp")
				local amount = petXp and petXp:FindFirstChild("Amount")

				local resultText = title and tostring(title.Text or "") or ""

				local xpText = "0"

				if amount then
					local lastText = ""
					local stableCount = 0

					for _ = 1, 20 do
						xpText = tostring(amount.Text or "")

						if xpText == lastText and xpText ~= "" then
							stableCount += 1

							if stableCount >= 5 then
								break
							end
						else
							stableCount = 0
							lastText = xpText
						end

						task.wait(0.05)
					end
				end
				local xpValue = parseGameNumber(xpText)

				sessionPetXp = sessionPetXp + xpValue

				local outcome = "Battle"

				if resultText:lower():find("victory") then
					outcome = "Won Battle"
					sessionWins += 1
					sessionBattles += 1
				elseif resultText:lower():find("lost") then
					outcome = "Lost Battle"
					sessionLosses += 1
					sessionBattles += 1
				end

				local chestText = ""

				if outcome == "Won Battle" then
					if battleChestName then
						chestText = " | Won " .. battleChestName

						sessionChestCounts[battleChestName] =
							(sessionChestCounts[battleChestName] or 0) + 1
					else
						chestText = " | No Chest Won"
					end
				end

				task.spawn(function()
					local webhookChest = "No Chest Won"

					if outcome == "Won Battle" and battleChestName then
						webhookChest = battleChestName
					end

					pendingWebhookData = {
						Outcome = outcome,
						XPGained = formatGameNumber(xpValue),
						SessionXP = formatGameNumber(sessionPetXp),
						Chest = webhookChest,
						Wins = sessionWins,
						Losses = sessionLosses,
						Battles = sessionBattles,
					}
				end)

				if outcome == "Lost Battle" then
					task.spawn(function()
						sendBattleWebhook(pendingWebhookData)
					end)

					pendingWebhookData = nil
				end

				lastRevealProcessed = true
			end

			battleChestName = nil

			setStatus("Result screen visible. Waiting...", Color3.fromRGB(255, 170, 0))
			task.wait(0.35)
			continue
		else
			lastRevealProcessed = false
		end

		local inBattle = isBattleOrRoundActive()

		if inBattle and not lastBattleState then
			battleChestChecked = false

			task.delay(1, function()
				if not isBattleOrRoundActive() then
					return
				end

				if battleChestChecked then
					return
				end

				battleChestChecked = true

				local chest = game:GetService("Players")
					.LocalPlayer
					.PlayerGui
					.Round
					.RoundContent
					:FindFirstChild("Chest")

				if chest and chest.Visible then
					local chestName = "Unknown Chest"

					local icon = chest:FindFirstChild("Icon")
					local image = icon and tostring(icon.Image or "")

					local chestMap = {
						["rbxassetid://100219197072623"] = "Basic Chest",
						["rbxassetid://78332757004195"] = "Noble Chest",
						["rbxassetid://112069144147496"] = "Hero Chest",
						["rbxassetid://111471816707639"] = "Rare Chest",
						["rbxassetid://132101813019914"] = "Epic Chest",
						["rbxassetid://131712819061732"] = "Mythic Chest",
						["rbxassetid://74309830568089"] = "Forest Chest",
						["rbxassetid://134302196219331"] = "Desert Chest",
						["rbxassetid://116058552043832"] = "Frozen Chest",
						["rbxassetid://139753554484995"] = "Beach Chest",
						["rbxassetid://72866903855185"] = "Castle/Boss Chest",
						["rbxassetid://105379627901281"] = "Savannah Chest",
					}

					if chestMap[image] then
						chestName = chestMap[image]
					end

					battleChestName = chestName
				else
				end
			end)
		end

		if not inBattle then
			battleChestChecked = false
		end

		lastBattleState = inBattle

		if inBattle then
			setStatus("In battle...", Color3.fromRGB(100, 150, 255))
			task.wait(0.5)
			continue
		end

		if not autoFarmEnabled then
			continue
		end
		if not autoStartBattleEnabled then
			setStatus("Auto Start Battle OFF", Color3.fromRGB(255, 170, 0))
			task.wait(0.5)
			continue
		end

		pcall(function()
			startBattleSmart()
		end)
	end
end


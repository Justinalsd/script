function extractPetId(value)
	if type(value) == "string" or type(value) == "number" then
		return tostring(value)
	end

	if type(value) == "table" then
		local keys = {
			"petId",
			"id",
			"uid",
			"uuid",
			"PetId",
			"PetID",
			"pet_id",
		}

		for _, key in ipairs(keys) do
			if value[key] ~= nil then
				return tostring(value[key])
			end
		end
	end

	return nil
end

function forEachPetId(data, callback)
	if type(data) ~= "table" or type(data.pets) ~= "table" then
		return 0
	end

	local seen = {}
	local count = 0

	for key, value in pairs(data.pets) do
		local petId = nil

		if type(key) == "string" and key ~= "" then
			petId = key
		elseif type(key) == "number" then
			petId = extractPetId(value) or tostring(key)
		end

		petId = extractPetId(value) or petId

		if petId and petId ~= "" and not seen[petId] then
			seen[petId] = true
			count += 1
			callback(tostring(petId), value, key)
		end
	end

	return count
end

function buildEquippedSet(data)
	local set = {}

	local function add(value)
		local petId = extractPetId(value)
		if petId and petId ~= "" then
			set[petId] = true
		end
	end

	local sources = {
		data and data.equipped,
		data and data.equippedPets,
		data and data.equippedTeam,
		data and data.team,
		data and data.slots,
		data and data.loadout,
	}

	for _, source in ipairs(sources) do
		if type(source) == "table" then
			for _, value in pairs(source) do
				add(value)
			end
		end
	end

	if type(data) == "table" and type(data.teams) == "table" then
		for _, team in pairs(data.teams) do
			if type(team) == "table" then
				for _, value in pairs(team) do
					add(value)
				end
			end
		end
	end

	return set
end

function countPets(data)

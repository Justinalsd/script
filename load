		lastAttemptAt = tick() + MATCH_SPEED_2X_ONCE_DELAY,
	})
	setStatus("2x: scheduled after " .. tostring(MATCH_SPEED_2X_ONCE_DELAY) .. "s", Color3.fromRGB(100, 200, 255))
    task.delay(MATCH_SPEED_2X_ONCE_DELAY, function()
        matchSpeed2xPendingThisBattle = false
        if matchSpeed2xClickedThisBattle then return end
        if not autoFarmEnabled then return end
        if not isBattleOrRoundActive() or isResultScreenVisible() then
			setMatchSpeedDebug("scheduled_cancelled", {
				lastReason = "not_in_battle_or_result_visible",

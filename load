			return
		end
		if not autoFarmEnabled then
			okReturn, modeReturn = false, "auto_farm_off"
			return
		end

		local clicked, clickReason = clickRewardEntryMulti(entry, tostring(chooseReason or "best_reward"))
		if clicked then

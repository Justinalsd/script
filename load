    clearBtn.Position = UDim2.new(1, -(clearW + 10), 0, topY)
    clearBtn.BackgroundColor3 = Color3.fromRGB(145, 45, 50)
    clearBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    clearBtn.Font = Enum.Font.GothamBold
    clearBtn.TextSize = TEXT_10
    clearBtn.Text = "Clear All"
    clearBtn.BorderSizePixel = 0
    clearBtn.Parent = row
    newCorner(clearBtn, 7)

    local info = Instance.new("TextLabel")
    info.BackgroundTransparency = 1
    info.Size = UDim2.new(1, -20, 0, math.floor(22 * scale))
    info.Position = UDim2.new(0, 10, 0, topY + btnH + math.floor(4 * scale))
    info.TextColor3 = Color3.fromRGB(165, 190, 230)
    info.Font = Enum.Font.GothamSemibold
    info.TextSize = TEXT_10
    info.TextXAlignment = Enum.TextXAlignment.Left
    info.TextTruncate = Enum.TextTruncate.AtEnd
    info.Text = "Loading inventory pets..."
    info.Parent = row

    local listTop = topY + btnH + math.floor(30 * scale)
    local list = Instance.new("ScrollingFrame")
    list.Name = "BattlePetLockList"
    list.Size = UDim2.new(1, -18, 1, -(listTop + 10))
    list.Position = UDim2.new(0, 9, 0, listTop)
    list.BackgroundColor3 = Color3.fromRGB(12, 18, 35)
    list.BorderSizePixel = 0
    list.ScrollBarThickness = isMobile and 4 or 3
    list.CanvasSize = UDim2.new(0, 0, 0, 0)
    list.Parent = row
    newCorner(list, 8)
    newStroke(list, Color3.fromRGB(65, 105, 170), 0.70, 1)

    local listLayout = Instance.new("UIListLayout")
    listLayout.Padding = UDim.new(0, 5)
    listLayout.SortOrder = Enum.SortOrder.LayoutOrder
    listLayout.Parent = list
    listLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        list.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y + 8)
    end)

    local lastItems = {}
    local function clearList()
        for _, child in ipairs(list:GetChildren()) do
            if child:IsA("GuiObject") then child:Destroy() end
        end
    end

    local function getFilteredItems(items)
        local q = tostring(search.Text or ""):lower():gsub("^%s+", ""):gsub("%s+$", "")
        if q == "" then return items end
        local out = {}
        for _, item in ipairs(items) do
            local text = (tostring(item.name or "") .. " " .. tostring(item.tier or "") .. " lv" .. tostring(item.level or "")):lower()
            if text:find(q, 1, true) then
                out[#out + 1] = item
            end
        end
        return out
    end

    local function countLocked(items)
        local count = 0
        for _, item in ipairs(items or {}) do
            if item.locked == true then count += 1 end
        end
        return count
    end

    local function redrawList()
        clearList()
        local shown = getFilteredItems(lastItems)
        info.Text = "Selected: " .. tostring(countLocked(lastItems)) .. " / " .. tostring(#lastItems) .. "   Showing: " .. tostring(#shown)

        if #lastItems == 0 then
            local empty = Instance.new("TextLabel")
            empty.Size = UDim2.new(1, -8, 0, SMALL_ROW_H)
            empty.BackgroundColor3 = Color3.fromRGB(70, 42, 42)
            empty.TextColor3 = Color3.fromRGB(255, 220, 220)
            empty.Font = Enum.Font.GothamSemibold
            empty.TextSize = TEXT_10
            empty.TextXAlignment = Enum.TextXAlignment.Left
            empty.Text = "  No pets found. Open inventory once, then Refresh."
            empty.BorderSizePixel = 0
            empty.Parent = list
            newCorner(empty, 6)
            return
        end

        if #shown == 0 then
            local empty = Instance.new("TextLabel")
            empty.Size = UDim2.new(1, -8, 0, SMALL_ROW_H)
            empty.BackgroundColor3 = Color3.fromRGB(21, 26, 43)
            empty.TextColor3 = Color3.fromRGB(170, 180, 200)
            empty.Font = Enum.Font.GothamSemibold
            empty.TextSize = TEXT_10
            empty.TextXAlignment = Enum.TextXAlignment.Left
            empty.Text = "  No pets match the search."
            empty.BorderSizePixel = 0
            empty.Parent = list
            newCorner(empty, 6)
            return
        end

        for _, item in ipairs(shown) do
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1, -8, 0, math.floor((isMobile and 36 or 38) * scale))
            btn.BackgroundColor3 = item.locked and Color3.fromRGB(25, 78, 120) or Color3.fromRGB(21, 26, 43)
            btn.TextColor3 = Color3.fromRGB(235, 240, 255)
            btn.Font = Enum.Font.GothamBold
            btn.TextSize = TEXT_10
            btn.TextXAlignment = Enum.TextXAlignment.Left
            btn.TextTruncate = Enum.TextTruncate.AtEnd
            btn.BorderSizePixel = 0
            local countText = (tonumber(item.count) or 0) > 1 and (" x" .. tostring(item.count)) or ""
            btn.Text = "  " .. (item.locked and "✓ LOCK  " or "□       ") .. tostring(item.name or "Unknown") .. "  Lv." .. tostring(item.level or 0) .. countText .. "  [" .. tostring(item.tier or "?") .. "]"
            btn.Parent = list
            newCorner(btn, 6)
            bindPress(btn, function()
                item.locked = not item.locked
                safeCall(function()
                    if EtherHubCore.SetPetNameLevelLock then
                        EtherHubCore.SetPetNameLevelLock(item.key, item.locked)
                    end
                end)
                setStatus((item.locked and "Locked " or "Unlocked ") .. tostring(item.name or "Pet") .. " Lv." .. tostring(item.level or 0), Color3.fromRGB(0, 220, 255))
                redrawList()
            end)
        end
    end

    local function refreshPets()
        local items = safeCall(function()
            return EtherHubCore.GetPetInventoryLockList and EtherHubCore.GetPetInventoryLockList()
        end) or {}
        if type(items) ~= "table" then items = {} end
        lastItems = items
        redrawList()
    end

    bindPress(refreshBtn, function()
        refreshPets()
        setStatus("Battle pet lock list refreshed", Color3.fromRGB(0, 220, 255))
    end)

    bindPress(clearBtn, function()
        local cleared = false
        safeCall(function()
            if EtherHubCore.ClearPetNameLevelLocks then
                EtherHubCore.ClearPetNameLevelLocks()
                cleared = true
            end
        end)
        if not cleared then
            for _, item in ipairs(lastItems) do
                item.locked = false
                safeCall(function()
                    if EtherHubCore.SetPetNameLevelLock then
                        EtherHubCore.SetPetNameLevelLock(item.key, false)
                    end
                end)
            end
        end
        for _, item in ipairs(lastItems) do item.locked = false end
        redrawList()
        setStatus("Cleared all battle pet locks", Color3.fromRGB(255, 170, 0))
    end)

    search:GetPropertyChangedSignal("Text"):Connect(function()
        redrawList()
    end)

    refreshPets()
    return { refresh = refreshPets, row = row }
end

local function getStealCriterion(name, fallback)
    local value = safeCall(function() return EtherHubCore.GetStealCriterion and EtherHubCore.GetStealCriterion(name) end)
    if type(value) == "boolean" then return value end
    return fallback
end

local function setStealCriterionUi(name, value)
    safeCall(function() if EtherHubCore.SetStealCriterion then EtherHubCore.SetStealCriterion(name, value == true) end end)
end

local function getSellTierLock(name)
    return safeCall(function() return EtherHubCore.GetSellTierLock and EtherHubCore.GetSellTierLock(name) end) == true
end

local function setSellTierLock(name, value)
    safeCall(function() if EtherHubCore.SetSellTierLock then EtherHubCore.SetSellTierLock(name, value == true) end end)
end

local SKILL_OPTIONS = {"Damage","Splash","Freeze","StealAtk","Steal","Heal","Summon","BuffAtk","BuffHp","BuffBoth","DebuffAtk","DebuffBoth","Clone","Devour","CopySkill","Shield"}
local function getStealSkill(name)
    local skills = safeCall(function() return EtherHubCore.GetStealSkills and EtherHubCore.GetStealSkills() end) or {}
    if type(skills) == "table" and type(skills[name]) == "boolean" then return skills[name] end
    return true
end
local function setStealSkill(name, value)
    safeCall(function() if EtherHubCore.SetStealSkill then EtherHubCore.SetStealSkill(name, value == true) end end)
end

local function summaryFromPairs(pairsList)
    local selected = {}
    for _, item in ipairs(pairsList) do
        if item.get() then selected[#selected + 1] = item.label end
    end
    if #selected == 0 then return "None" end
    if #selected > 3 then return tostring(#selected) .. " Selected" end
    return table.concat(selected, "+")
end


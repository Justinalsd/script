function equipBestDirect()

	if not autoEquipBestEnabled then return false end
	if equipBestUiBusy then

		return false
	end
	if tick() - lastEquipBestUiRunAt < EQUIPBEST_UI_COOLDOWN then

		return false
	end
	if isBattleOrRoundActive() or isResultScreenVisible() then return false end

	equipBestUiBusy = true
	lastEquipBestUiRunAt = tick()

	local restoreUI = nil
	local okResult = false
	local finalReason = "not_started"
	local openedByThisRun = false

	local function localIsVisible(obj)
		if not obj or not obj:IsA("GuiObject") or not obj:IsDescendantOf(game) then
			return false
		end

		local cur = obj
		while cur and cur ~= playerGui and cur ~= CoreGui do
			if cur:IsA("ScreenGui") and cur.Enabled == false then
				return false
			end
			if cur:IsA("GuiObject") and cur.Visible == false then
				return false
			end
			cur = cur.Parent
		end

		return obj.AbsoluteSize.X > 0 and obj.AbsoluteSize.Y > 0
	end

	local function clickAt(btn, mode)
		if not localIsVisible(btn) then
			warn("[EtherHub] EquipBest target not visible:", btn and btn:GetFullName())
			return false
		end

		local pos = btn.AbsolutePosition
		local size = btn.AbsoluteSize
		local inset = GuiService:GetGuiInset()

		local x = pos.X + size.X * 0.5
		local y = pos.Y + size.Y * 0.5

		if mode == "center_with_inset" then
			y = y + inset.Y
		elseif mode == "lower_no_inset" then
			y = pos.Y + size.Y * 0.68
		elseif mode == "upper_no_inset" then
			y = pos.Y + size.Y * 0.32
		elseif mode == "left_center" then
			x = pos.X + size.X * 0.35
		elseif mode == "right_center" then
			x = pos.X + size.X * 0.65
		end

		x = math.floor(x)
		y = math.floor(y)

		local ok = sendTouchOrMouseClick(x, y, false)

		task.wait(isMobile and 0.28 or 0.25)
		return ok
	end

	local function getInventoryPets()
		local inv = playerGui:FindFirstChild("Inventory")
		local pets = inv and inv:FindFirstChild("Pets")
		if pets and localIsVisible(pets) then
			return pets
		end
		return nil
	end

	local function waitInventoryPets(timeout)
		local start = tick()
		while tick() - start < timeout do
			local pets = getInventoryPets()
			if pets then
				return pets
			end
			task.wait(0.1)
		end
		return nil
	end

	local function findEquipBestButton(pets)
		if not pets then return nil, "no_pets" end

		local exact = pets:FindFirstChild("EquipBest")
		if exact and exact:IsA("GuiButton") and localIsVisible(exact) then
			return exact, "exact_Inventory_Pets_EquipBest"
		end

		if exact and exact:IsA("GuiObject") then
			local childBtn = exact:FindFirstChildWhichIsA("GuiButton", true)
			if childBtn and localIsVisible(childBtn) then
				return childBtn, "EquipBest_child_GuiButton"
			end
		end

		for _, obj in ipairs(pets:GetDescendants()) do
			if obj:IsA("GuiButton") and localIsVisible(obj) then
				local name = string.lower(obj.Name or "")
				local text = ""
				pcall(function()
					text = string.lower(obj.Text or "")
				end)
				local full = string.lower(obj:GetFullName())

				if name:find("equip") or name:find("best") or text:find("equip") or text:find("best") or full:find("equipbest") then
					return obj, "fallback_" .. obj.Name
				end
			end
		end

		return nil, "not_found"
	end

	local function hideEtherHubUI()
		local oldStates = {}

		local targets = {
			ScreenGui,
			playerGui:FindFirstChild("EtherHubAutoFarmFixed"),
			CoreGui:FindFirstChild("EtherHubAutoFarmFixed"),
			playerGui:FindFirstChild("EtherHubAutoFarm"),
			CoreGui:FindFirstChild("EtherHubAutoFarm"),
			playerGui:FindFirstChild("EtherHub"),
			CoreGui:FindFirstChild("EtherHub"),
		}

		for _, gui in ipairs(targets) do
			if gui and gui:IsA("ScreenGui") and oldStates[gui] == nil then
				oldStates[gui] = gui.Enabled
				gui.Enabled = false

			elseif gui and gui:IsA("GuiObject") and oldStates[gui] == nil then
				oldStates[gui] = gui.Visible
				gui.Visible = false

			end
		end

		return function()
			for gui, state in pairs(oldStates) do
				if gui and gui.Parent then
					if gui:IsA("ScreenGui") then
						gui.Enabled = state
					elseif gui:IsA("GuiObject") then
						gui.Visible = state
					end

				end
			end
		end
	end

	local function fireCloseInventory(reason)

		if S_ClosePanel then
			pcall(function()
				S_ClosePanel:Fire("Inventory")
			end)
		end
	end

	local function fireOpenInventoryOnce()

		local currentPets = getInventoryPets()
		if currentPets then
			return currentPets, "already_open", false
		end

		if tick() - lastInventoryOpenSignalAt < INVENTORY_OPEN_SIGNAL_COOLDOWN then
			local pendingPets = waitInventoryPets(2.0)
			if pendingPets then
				return pendingPets, "waited_existing_open_signal", false
			end
		end

		lastInventoryOpenSignalAt = tick()

		if S_OpenPanel then
			pcall(function()
				S_OpenPanel:Fire("Inventory")
			end)
		end

		local pets = waitInventoryPets(5)
		return pets, "opened_once", pets ~= nil
	end

	local okRun, err = pcall(function()
		setStatus("Equip best: UI click mode...", Color3.fromRGB(100, 200, 255))
		restoreUI = hideEtherHubUI()

		local pets, openReason, didOpen = fireOpenInventoryOnce()
		openedByThisRun = didOpen == true
		if not pets then
			finalReason = "Inventory.Pets not visible"
			warn("[EtherHub] EquipBest Inventory.Pets not visible")
			return
		end

		local inv = playerGui:FindFirstChild("Inventory")
		local beforeStatus = inv and inv:GetAttribute("EquipBestLastStatus")
		local beforeBusy = inv and inv:GetAttribute("EquipBestBusy")

		local btn, reason = findEquipBestButton(pets)
		if not btn then
			finalReason = "EquipBest button not found: " .. tostring(reason)
			warn("[EtherHub] EquipBest button not found:", tostring(reason))

			for _, obj in ipairs(pets:GetDescendants()) do
				if obj:IsA("GuiButton") and localIsVisible(obj) then
					local txt = ""
					pcall(function() txt = tostring(obj.Text) end)

				end
			end
			return
		end

		pcall(function()
			if btn:IsA("GuiButton") then
				btn.Active = true
				btn.Selectable = true
				btn.AutoButtonColor = true
			end
		end)

		local modes = {
			"center_no_inset",
			"center_with_inset",
			"lower_no_inset",
			"upper_no_inset",
			"left_center",
			"right_center",
		}

		for i, mode in ipairs(modes) do
			local ok = clickAt(btn, mode)

			task.wait(0.35)

			local afterStatus = inv and inv:GetAttribute("EquipBestLastStatus")
			local afterBusy = inv and inv:GetAttribute("EquipBestBusy")

			if afterStatus ~= beforeStatus or afterBusy == true or tostring(afterBusy) ~= tostring(beforeBusy) then
				okResult = true
				finalReason = "triggered_by_" .. tostring(mode)

				break
			end
		end

		if not okResult then

			okResult = true
			finalReason = "clicked_all_modes_no_attr_change"

		end

		task.wait(0.6)
	end)

	if not okRun then
		finalReason = tostring(err)
		warn("[EtherHub] EquipBest error:", tostring(err))
	end

	if openedByThisRun and getgenv().EtherHubCloseInventoryAfterEquipBest ~= false then
		fireCloseInventory("after_equipbest")
		task.wait(0.2)
	end

	if restoreUI then
		restoreUI()
	end

	equipBestUiBusy = false

	if okResult then
		pcall(function()
			getPlayerData("all")
		end)
		setStatus("Equip best UI done", Color3.fromRGB(0, 255, 150))

		return true
	end

	setStatus("Equip best UI failed: " .. tostring(finalReason), Color3.fromRGB(255, 80, 80))
	warn("[EtherHub] EquipBest failed:", tostring(finalReason))
	return false
end


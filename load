function setMatchSpeedSafe(speed)
	speed = tonumber(speed) or 1
	speed = speed >= 2 and 2 or 1

	if speed == 2 then
		if not checkMatchSpeed2xAllowed(false) then
			setMatchSpeedDebug("blocked_no_gamepass", {
				lastAllowed = false,
				lastReason = "matchspeed_2x_gamepass_not_owned",
			})
			return false, "matchspeed_2x_gamepass_not_owned"
		end

		setMatchSpeedDebug("attempting_2x", {
			lastAllowed = true,
			lastAttemptAt = tick(),
			lastReason = "attempting_set_matchspeed_2",
		})
		setStatus("2x: enabling...", Color3.fromRGB(100, 200, 255))

		local uiOk, uiReason = clickMatchSpeed2xButton()
		if uiOk then
			setMatchSpeedDebug("enabled_ui", {
				lastReason = uiReason,
			})
			return true, uiReason
		end

		local remoteOk, remoteReason = setMatchSpeedRemote(2)
		if remoteOk then
			setMatchSpeedDebug("enabled_remote_fallback", {
				lastReason = remoteReason,
			})
			return true, remoteReason
		end

		setMatchSpeedDebug("enable_failed", {
			lastReason = tostring(uiReason) .. "|" .. tostring(remoteReason),
		})
		return false, tostring(uiReason) .. "|" .. tostring(remoteReason)
	end

	return false, "speed_1_no_action"
end

function autoSetMatchSpeed2xIfAllowed(reason)
	if matchSpeed2xClickedThisBattle then
		return false, "matchspeed_already_clicked_this_battle"
	end
	if autoMatchSpeed2xEnabled ~= true then
		return false, "auto_disabled"
	end

	if not checkMatchSpeed2xAllowed(false) then
		return false, "matchspeed_2x_gamepass_not_owned"
	end

	local ok, result = setMatchSpeedSafe(2)
	if ok then
		matchSpeed2xClickedThisBattle = true
		setMatchSpeedDebug("enabled", {
			lastReason = tostring(result),
		})
		setStatus("2x enabled: " .. tostring(result), Color3.fromRGB(0, 255, 150))

    local current = math.clamp(math.floor(tonumber(value) or minValue), minValue, maxValue)
    amount.Text = tostring(current)

    local function setValue(v)
        local n = tonumber(tostring(v or ""):match("%-?%d+"))
        if not n then n = current end
        current = math.clamp(math.floor(n), minValue, maxValue)
        amount.Text = tostring(current)
        callback(current)
        coreSave()
    end

    amount:GetPropertyChangedSignal("Text"):Connect(function()
        local clean = tostring(amount.Text or ""):gsub("[^%d%-]", "")
        if clean ~= amount.Text then
            amount.Text = clean
        end
    end)

    amount.FocusLost:Connect(function()
        setValue(amount.Text)
    end)

    bindPress(minus, function() setValue(current - 1) end)
    bindPress(plus, function() setValue(current + 1) end)
end


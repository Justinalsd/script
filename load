function scheduleMatchSpeed2xOnce(reason)
    if matchSpeed2xClickedThisBattle or matchSpeed2xPendingThisBattle then
		setMatchSpeedDebug("schedule_skipped", {
			lastReason = "matchspeed_already_scheduled",
		})
        return false, "matchspeed_already_scheduled"
    end

    matchSpeed2xPendingThisBattle = true
	setMatchSpeedDebug("scheduled", {

	end

	setMatchSpeedDebug("auto_failed", {
		lastReason = tostring(result),
	})
	setStatus("2x failed: " .. tostring(result), Color3.fromRGB(255, 170, 0))
	return false, result
end

autoSellBusy = false
lastAutoSellLoopAt = 0
AUTO_SELL_LOOP_DELAY = 2.25

function runAutoSellOnly(isForced)
	if autoSellBusy then return false end
	if not isForced and not autoFarmEnabled then return false end
	if not isForced and (isBattleOrRoundActive() or isResultScreenVisible()) then return false end

	autoSellBusy = true
	working = true
	workingStartedAt = tick()

	local ok, err = pcall(function()
		runDirectAutoSell(isForced)
	end)

	working = false
	workingStartedAt = 0
	autoSellBusy = false

	if not ok then
		warn("[EtherHub] Auto sell recovered:", err)
		setStatus("Auto sell recovered", Color3.fromRGB(255, 170, 0))
		return false
	end

	return true
end

function runDirectAutoSell(isForced)
	local data = getPlayerData("all")
	if not data then
		setStatus("Error: GetPlayerData failed", Color3.fromRGB(255, 80, 80))
		return
	end

	if type(prunePetNameLevelLocks) == "function" then
		prunePetNameLevelLocks(data, true)
	end

	local currentCount = countPets(data)
	if not isForced and currentCount <= START_SELL_AT then
		setStatus("Inventory OK (" .. currentCount .. "/" .. START_SELL_AT .. ")", Color3.fromRGB(0, 255, 150))
		return
	end

	local attempts = 0
	while currentCount > KEEP_PET_LIMIT and attempts < 80 do
		attempts += 1
		local petId = getWeakestSellablePet(data)
		if not petId then
			setStatus("No sellable pets", Color3.fromRGB(255, 170, 0))
			break
		end

		setStatus("Selling " .. petId .. "...", Color3.fromRGB(255, 170, 0))
		if sellPetDirect(petId) then
			setStatus("✓ Sold " .. petId, Color3.fromRGB(0, 255, 150))
			task.wait(0.35)
		else
			setStatus("Sell failed: " .. petId, Color3.fromRGB(255, 80, 80))
			break
		end

		data = getPlayerData("all")
		if not data then break end
		if type(prunePetNameLevelLocks) == "function" then
			prunePetNameLevelLocks(data, true)
		end
		currentCount = countPets(data)
	end

	setStatus("Cleaned (" .. tostring(currentCount) .. " pets)", Color3.fromRGB(0, 255, 150))
end

function runCleanSystem(isForced)
	if not isForced and not autoFarmEnabled then return end
	if working then return end

	if not isForced and tick() - (lastCleanSystemRunAt or 0) < CLEAN_SYSTEM_COOLDOWN then
		return
	end
	lastCleanSystemRunAt = tick()

	working = true
	workingStartedAt = tick()

	local okRun, err = pcall(function()
		if not isForced and not autoFarmEnabled then return end

		pcall(function()
			if not isForced and not autoFarmEnabled then return end
			runDirectAutoSell(isForced)
		end)

		local leveled = false
		if autoLevelUpEnabled then
			pcall(function()
				if not isForced and not autoFarmEnabled then return end
				leveled = levelUpEquippedDirect() == true
			end)
		end

		pcall(function()
			if not isForced and not autoFarmEnabled then return end
			equipBestSafe(leveled and "after_level_up_once" or "clean_system_once")
		end)

		pcall(function()
			if not isForced and not autoFarmEnabled then return end
			runDirectAutoSell(isForced)
		end)
	end)

	working = false
	workingStartedAt = 0
	if not okRun then
		warn("[EtherHub] Clean system recovered:", err)
		setStatus("Recovered clean system", Color3.fromRGB(255, 170, 0))
	else
		setStatus("Standing by", Color3.fromRGB(0, 255, 150))
	end
end


chestClaimedRecently = {}
chestBusy = false

CHEST_TYPE_BASE_SCORE = {
	pet = 100000,
	hat = 95000,
	forgegems = 65000,
	petxp = 45000,
	other = 10000,
}

CHEST_TIER_WEIGHTS = {
	Secret = 10,
	Divine = 9,
	Exotic = 8,
	Exclusive = 7,
	Mythic = 6,
	Legendary = 5,
	Epic = 4,
	Rare = 3,
	Uncommon = 2,
	Common = 1,
}

function chestLower(v)
	return tostring(v or ""):lower()
end

function chestDeepTextBlob(value, visited)
	visited = visited or {}
	local t = type(value)
	if t == "string" or t == "number" or t == "boolean" then
		return " " .. chestLower(value) .. " "
	end
	if t ~= "table" or visited[value] then
		return ""
	end

	visited[value] = true
	local parts = {}
	for k, v in pairs(value) do
		parts[#parts + 1] = chestDeepTextBlob(k, visited)
		parts[#parts + 1] = chestDeepTextBlob(v, visited)
	end
	return table.concat(parts, " ")
end

function chestRewardTextHas(reward, patterns)
	local blob = chestDeepTextBlob(reward):gsub("[%s_%-%./]", "")
	for _, pattern in ipairs(patterns or {}) do
		if blob:find(tostring(pattern):lower():gsub("[%s_%-%./]", ""), 1, true) then
			return true
		end
	end
	return false
end

function chestNumber(v)
	return tonumber(v) or 0
end

function chestNormalizeRewardType(reward)
	if type(reward) ~= "table" then
		return "other"
	end

	local rt = chestLower(reward.rewardType or reward.type or reward.Type or reward.kind or reward.rewardKind)
	local name = chestLower(reward.name or reward.id or reward.itemId or reward.rewardId or reward.title)
	local category = chestLower(reward.category or reward.class or reward.itemType)

	if rt:find("petautosold") then
		return "pet"
	end
	if rt:find("petxp") or rt:find("pet_xp") or rt:find("xp") or name:find("petxp") or name:find("pet xp") then
		return "petxp"
	end
	if rt:find("forgegems") or rt:find("forge_gems") or rt:find("forge") or rt:find("gem") or name:find("forge") or name:find("gem") then
		return "forgegems"
	end
	if rt:find("hat") or category:find("hat") or name:find("hat") then
		return "hat"
	end
	if rt:find("pet") or category:find("pet") or name:find("pet") then
		return "pet"
	end
	if chestRewardTextHas(reward, {"petxp", "pet experience", "petexp"}) then
		return "petxp"
	end
	if chestRewardTextHas(reward, {"forgegems", "forge gem", "forge", "gem"}) then
		return "forgegems"
	end
	if chestRewardTextHas(reward, {"hat"}) then
		return "hat"
	end
	if chestRewardTextHas(reward, {"pet"}) then
		return "pet"
	end

	return "other"
end

function chestDeepFindTier(tbl, visited)
	if type(tbl) ~= "table" then return nil end
	visited = visited or {}
	if visited[tbl] then return nil end
	visited[tbl] = true

	for _, v in pairs(tbl) do
		if type(v) == "string" then
			for tierName in pairs(CHEST_TIER_WEIGHTS) do
				if chestLower(v):find(chestLower(tierName), 1, true) then
					return tierName
				end
			end
		elseif type(v) == "table" then
			local found = chestDeepFindTier(v, visited)
			if found then return found end
		end
	end

	return nil
end

function chestGetTierName(reward)
	if type(reward) ~= "table" then return "Common" end

	local direct = reward.tierName or reward.tier or reward.rarity or reward.Tier or reward.Rarity
	if direct and tostring(direct) ~= "" then
		local s = tostring(direct)
		for tierName in pairs(CHEST_TIER_WEIGHTS) do
			if chestLower(s):find(chestLower(tierName), 1, true) then
				return tierName
			end
		end
		return s
	end

	return chestDeepFindTier(reward) or "Common"
end

function chestTierWeight(tier)
	local s = tostring(tier or "")
	for tierName, weight in pairs(CHEST_TIER_WEIGHTS) do
		if chestLower(s):find(chestLower(tierName), 1, true) then
			return weight
		end
	end
	return 1
end

function chestFindNumberByKeys(tbl, keys, visited)
	if type(tbl) ~= "table" then return 0 end
	visited = visited or {}
	if visited[tbl] then return 0 end
	visited[tbl] = true

	for k, v in pairs(tbl) do
		local key = chestLower(k):gsub("[%s_%-%./]", "")
		for _, wanted in ipairs(keys) do
			if key == wanted or key:find(wanted, 1, true) then
				local n = tonumber(v)
				if n then return n end
			end
		end
		if type(v) == "table" then
			local found = chestFindNumberByKeys(v, keys, visited)
			if found and found ~= 0 then return found end
		end
	end

	return 0
end

function chestRewardAmount(reward)
	if type(reward) ~= "table" then return 0 end
	return chestNumber(reward.amount)
		+ chestNumber(reward.value)
		+ chestNumber(reward.qty)
		+ chestNumber(reward.quantity)
		+ chestNumber(reward.petXpGain)
		+ chestNumber(reward.forgeGems)
		+ chestNumber(reward.forgeStones)
end

function chestRewardStat(reward, stat)
	if type(reward) ~= "table" then return 0 end

	if stat == "level" then
		return chestNumber(reward.level or reward.Level)
			+ chestFindNumberByKeys(reward, {"level", "lvl"})
	elseif stat == "damage" then
		return chestNumber(reward.damage or reward.Damage or reward.power or reward.Power or reward.atk or reward.attack)
			+ chestFindNumberByKeys(reward, {"damage", "dmg", "power", "atk", "attack"})
	elseif stat == "health" then
		return chestNumber(reward.health or reward.Health or reward.hp or reward.HP)
			+ chestFindNumberByKeys(reward, {"health", "hp", "defense", "defence"})
	end

	return 0
end

function chestScoreReward(reward)
	if type(reward) ~= "table" then return -math.huge end

	local rtype = chestNormalizeRewardType(reward)
	local tier = chestGetTierName(reward)
	local level = chestRewardStat(reward, "level")
	local damage = chestRewardStat(reward, "damage")
	local health = chestRewardStat(reward, "health")
	local amount = chestRewardAmount(reward)
	local tierBase = tonumber(TIER_BASE_SCORE) or 1000000000
	local criteriaTier = rewardUseTier()
	local criteriaLevel = rewardUseLevel()
	local criteriaDamage = rewardUseDamage()
	local criteriaHealth = rewardUseHealth()
	local amountScore = (rtype == "pet" or rtype == "hat") and 0 or amount

	return (CHEST_TYPE_BASE_SCORE[rtype] or CHEST_TYPE_BASE_SCORE.other)
		+ (criteriaTier and (chestTierWeight(tier) * tierBase) or 0)
		+ (criteriaLevel and (level * 100) or 0)
		+ (criteriaDamage and (damage * 2) or 0)
		+ (criteriaHealth and (health * 0.5) or 0)
		+ amountScore
end

function chestCardsFromRewardRoll(rewardRoll)
	if type(rewardRoll) ~= "table" then return nil end
	if type(rewardRoll.cards) == "table" then return rewardRoll.cards end
	if type(rewardRoll.rewards) == "table" then return rewardRoll.rewards end
	if type(rewardRoll.rewardCards) == "table" then return rewardRoll.rewardCards end
	return nil
end

function chestFindBestByFilter(cards, filterFn)
	local bestIndex, bestReward, bestScore = nil, nil, -math.huge
	for i, reward in ipairs(cards or {}) do
		if filterFn(reward) then
			local score = chestScoreReward(reward)
			if score > bestScore then
				bestIndex, bestReward, bestScore = i, reward, score
			end
		end
	end
	return bestIndex, bestReward, bestScore
end

function chestFindBestOverall(cards)
	return chestFindBestByFilter(cards, function() return true end)
end

function chestFindBestOther(cards)
	return chestFindBestByFilter(cards, function(reward)
		local t = chestNormalizeRewardType(reward)
		return t ~= "pet" and t ~= "hat"
	end)
end

function chestPickText(index, reward, score, reason)
	if type(reward) ~= "table" then
		return tostring(reason or "no reward")
	end

	local rtype = chestNormalizeRewardType(reward)
	local name = tostring(reward.name or reward.title or reward.id or reward.rewardId or rtype)
	local tier = chestGetTierName(reward)

	return "#" .. tostring(index)
		.. " " .. name
		.. " | " .. rtype
		.. " | " .. tier
		.. " | Score:" .. tostring(math.floor(score or 0))
		.. " | " .. tostring(reason or "")
end

function chestChooseRewardIndexes(rewardRoll)
	local cards = chestCardsFromRewardRoll(rewardRoll)
	if type(cards) ~= "table" or #cards <= 0 then
		return {1}, "No cards detected, using first"
	end

	if chestRewardMode == "All if Unlocked" and type(rewardRoll) == "table" and rewardRoll.takeAllUnlocked == true then
		local all = {}
		for i = 1, #cards do all[#all + 1] = i end
		return all, "Take All unlocked"
	end

	if chestRewardMode == "First" then
		local score = chestScoreReward(cards[1])
		return {1}, chestPickText(1, cards[1], score, "First mode")
	end

	local idx, reward, score, reason

	if chestRewardMode == "Best" or chestRewardMode == "All if Unlocked" then
		idx, reward, score = chestFindBestOverall(cards)
		reason = "Best overall"
	elseif chestRewardMode == "Pet" then
		idx, reward, score = chestFindBestByFilter(cards, function(r) return chestNormalizeRewardType(r) == "pet" end)
		reason = "Pet selected"
		if not idx then
			idx, reward, score = chestFindBestByFilter(cards, function(r) return chestNormalizeRewardType(r) == "hat" end)
			reason = "No Pet, fallback to best Hat"
		end
		if not idx then
			if chestFallbackMode == "SKIP" then return nil, "No Pet/Hat found and fallback is SKIP" end
			idx, reward, score = chestFindBestOther(cards)
			reason = "No Pet/Hat, fallback to best Other"
		end
		if not idx and chestFallbackMode ~= "SKIP" then
			idx, reward, score = chestFindBestOverall(cards)
			reason = "Fallback to best overall"
		end
	elseif chestRewardMode == "Hat" then
		idx, reward, score = chestFindBestByFilter(cards, function(r) return chestNormalizeRewardType(r) == "hat" end)
		reason = "Hat selected"
		if not idx then
			idx, reward, score = chestFindBestByFilter(cards, function(r) return chestNormalizeRewardType(r) == "pet" end)
			reason = "No Hat, fallback to best Pet"
		end
		if not idx then
			if chestFallbackMode == "SKIP" then return nil, "No Hat/Pet found and fallback is SKIP" end
			idx, reward, score = chestFindBestOther(cards)
			reason = "No Hat/Pet, fallback to best Other"
		end
		if not idx and chestFallbackMode ~= "SKIP" then
			idx, reward, score = chestFindBestOverall(cards)
			reason = "Fallback to best overall"
		end
	elseif chestRewardMode == "Pet XP" then
		idx, reward, score = chestFindBestByFilter(cards, function(r) return chestNormalizeRewardType(r) == "petxp" end)
		reason = "Pet XP selected"
		if not idx then
			if chestFallbackMode == "SKIP" then return nil, "No Pet XP found and fallback is SKIP" end
			idx, reward, score = chestFindBestOverall(cards)
			reason = "No Pet XP, fallback to best overall"
		end
	elseif chestRewardMode == "Forge Gems" then
		idx, reward, score = chestFindBestByFilter(cards, function(r) return chestNormalizeRewardType(r) == "forgegems" end)
		reason = "Forge Gems selected"
		if not idx then
			if chestFallbackMode == "SKIP" then return nil, "No Forge Gems found and fallback is SKIP" end
			idx, reward, score = chestFindBestOverall(cards)
			reason = "No Forge Gems, fallback to best overall"
		end
	else
		idx, reward, score = chestFindBestOverall(cards)
		reason = "Unknown mode, best overall"
	end

	if idx then
		return {idx}, chestPickText(idx, reward, score, reason)
	end

	return nil, "No valid reward"
end

function chestClearOldRecent()
	local t = tick()
	for id, expireAt in pairs(chestClaimedRecently) do
		if expireAt <= t then
			chestClaimedRecently[id] = nil
		end
	end
end

function chestGetData()
	if not RF_GetPlayerData then return nil end
	local ok, data = pcall(function()
		return RF_GetPlayerData:InvokeServer({
			dataScope = "chests",
			petDetails = "equipped",
			includeServerPlayers = false,
			includeMatchPreview = false,
			broadcast = false,
			maxCacheAge = 3,
			maxAttempts = 2,
			retryDelay = 0.1,
			allowSuspiciousBlank = true,
		})
	end)
	if ok and type(data) == "table" then return data end
	return nil
end

function chestIsReady(chest, serverTime)
	if type(chest) ~= "table" then return false end
	return (tonumber(chest.readyAt) or 0) <= (tonumber(serverTime) or os.time())
end

function chestOpenAndClaim(chestId)
	chestId = tostring(chestId or "")
	if chestId == "" then return false end
	if chestClaimedRecently[chestId] then return false end
	if not R_BeginChestOpen or not R_ClaimChestRewards then return false end

	chestClaimedRecently[chestId] = tick() + CHEST_RECENT_CACHE_TIME

	setStatus("Opening chest " .. chestId .. "...", Color3.fromRGB(100, 200, 255))

	local okOpen, openResult = invokeRemote(R_BeginChestOpen, chestId)
	if not okOpen or type(openResult) ~= "table" or openResult.success ~= true then
		local reason = type(openResult) == "table" and tostring(openResult.reason or openResult.message or "unknown") or tostring(openResult)
		setStatus("Chest begin failed: " .. reason, Color3.fromRGB(255, 170, 0))
		return false
	end

	task.wait(CHEST_OPEN_DELAY)

	local indexes, pickReason = chestChooseRewardIndexes(openResult.rewardRoll or openResult.roll or openResult.rewards)
	if not indexes or #indexes <= 0 then
		setStatus("Chest skipped: " .. tostring(pickReason), Color3.fromRGB(255, 205, 70))
		return false
	end

	task.wait(CHEST_CLAIM_DELAY)

	local okClaim, claimResult = invokeRemote(R_ClaimChestRewards, chestId, indexes)
	if okClaim and type(claimResult) == "table" and claimResult.success == true then
		setStatus("Chest claimed: " .. tostring(pickReason), Color3.fromRGB(0, 255, 150))
		return true
	end

	local reason = type(claimResult) == "table" and tostring(claimResult.reason or claimResult.message or "unknown") or tostring(claimResult)
	setStatus("Chest claim failed: " .. reason, Color3.fromRGB(255, 90, 90))
	return false
end

function chestAutoOpenOnce()
	if chestBusy or not autoOpenChestEnabled then return end
	chestBusy = true

	chestClearOldRecent()

	local data = chestGetData()
	if data and type(data.chests) == "table" then
		local serverTime = tonumber(data.serverTime) or os.time()
		local foundReady = false

		for _, chest in ipairs(data.chests) do
			if not autoOpenChestEnabled then break end
			local chestId = tostring(chest.id or chest.chestId or "")
			if chestId ~= "" and chestIsReady(chest, serverTime) then
				foundReady = true
				chestOpenAndClaim(chestId)
				task.wait(CHEST_COOLDOWN)
			end
		end

		if not foundReady and autoOpenChestEnabled then
			setStatus("No ready chests", Color3.fromRGB(210, 220, 245))
		end
	elseif autoOpenChestEnabled then
		setStatus("Could not read chest data", Color3.fromRGB(255, 170, 0))
	end

	chestBusy = false
end

task.spawn(function()
	while true do
		if autoOpenChestEnabled then
			pcall(chestAutoOpenOnce)
		end
		task.wait(CHEST_LOOP_DELAY)
	end
end)

function startBattleBySignal()
	if not autoFarmEnabled then
		return false, "auto_farm_off"
	end

	if not (S_StartBattleRequest and S_BattlePrepared and S_BeginPreparedBattle) then
		return false, "signals_missing"
	end

	if isBattleOrRoundActive() then
		return false, "round_active"
	end

	local token = math.floor(os.clock() * 1000000) % 1000000000
	local prepared = false
	local success = false
	local reason = nil

	local conn
	conn = S_BattlePrepared.Event:Connect(function(preparedToken, ok, failReason)
		if preparedToken ~= token then return end
		prepared = true
		success = ok == true
		reason = failReason
		if conn then
			conn:Disconnect()
			conn = nil
		end
	end)

	S_StartBattleRequest:Fire(token)

	local t0 = tick()
	while not prepared and tick() - t0 < 8 do
		if not autoFarmEnabled then
			if conn then
				conn:Disconnect()
				conn = nil
			end
			return false, "auto_farm_off"
		end
		task.wait(0.04)
	end

	if conn then
		conn:Disconnect()
		conn = nil
	end

	if not prepared then
		return false, "prepare_timeout"
	end
	if not success then
		return false, reason or "prepare_failed"
	end

	if not autoFarmEnabled then
		return false, "auto_farm_off"
	end

	S_BeginPreparedBattle:Fire(token)
	return true, "signal_started"
end

function startBattleByClick()
	if not autoFarmEnabled then
		return false, "auto_farm_off"
	end

	local play = getPlayButton()
	if play and isVisibleOnScreen(play) then
		return safeClick(play, false), "clicked_play"
	end
	return false, "play_not_found"
end

function startBattleSmart()
	if not autoFarmEnabled then return false end
	if not autoStartBattleEnabled then
		setStatus("Auto Start Battle OFF", Color3.fromRGB(255, 170, 0))
		return false
	end

	if working and workingStartedAt > 0 and tick() - workingStartedAt > WORKING_STUCK_TIMEOUT then
		working = false
		workingStartedAt = 0
		setStatus("Recovered stuck task", Color3.fromRGB(255, 170, 0))
	end
	if clickLock and clickLockStartedAt > 0 and tick() - clickLockStartedAt > CLICK_LOCK_STUCK_TIMEOUT then
		clickLock = false
		clickLockStartedAt = 0
		setStatus("Recovered stuck click", Color3.fromRGB(255, 170, 0))
	end
	if working then return false end
	if tick() - lastStartAttempt < 1.2 then return false end
	if tick() < nextPlayAllowedAt then
		local remain = math.max(0, nextPlayAllowedAt - tick())
		setStatus(string.format("Wait %.1fs before Play", remain), Color3.fromRGB(100, 150, 255))
		return false
	end

	lastStartAttempt = tick()

	if not waitForPlayReady(8) then
		setStatus("Waiting Play...", Color3.fromRGB(255, 170, 0))
		return false
	end
	if not autoFarmEnabled then return false end

	setStatus("Auto Play: starting by signal...", Color3.fromRGB(100, 200, 255))
	local signalOk, signalReason = startBattleBySignal()
	if signalOk then
		setStatus("Battle started by signal", Color3.fromRGB(0, 255, 150))
		task.delay(0.75, function()
			if not autoFarmEnabled then return end
			pcall(function()
				autoSetMatchSpeed2xIfAllowed("after_signal_start")
			end)
		end)
		return true
	end
	warn("[EtherHub] Signal battle failed:", signalReason)
	if not autoFarmEnabled then return false end

	if tostring(signalReason) == "prepare_timeout" then
		local rejoinOk, rejoinReason = EtherHubCore.RejoinOnPrepareTimeout("prepare_timeout")
		if rejoinOk then
			setStatus("Prepare timeout. Rejoining...", Color3.fromRGB(255, 170, 0))
		else
			setStatus("Prepare timeout: " .. tostring(rejoinReason), Color3.fromRGB(255, 170, 0))
		end
		return false
	end

	setStatus("Signal failed/timeout. Waiting next loop...", Color3.fromRGB(255, 170, 0))
	return false
end

if S_BattleEnded then
	S_BattleEnded.Event:Connect(function()
		matchSpeed2xClickedThisBattle = false
		matchSpeed2xPendingThisBattle = false
		if autoFarmEnabled then
			nextPlayAllowedAt = tick() + AFTER_BATTLE_PLAY_DELAY
			setStatus("Battle ended. Delay " .. tostring(AFTER_BATTLE_PLAY_DELAY) .. "s", Color3.fromRGB(100, 150, 255))
		end
	end)
end

CLAIM_CLICK_RETRY = 4
lastClaimCheckClickAt = 0

function getGuiButtonChild(root)
	if not root then return nil end
	if root:IsA("GuiButton") and isVisibleOnScreen(root) then
		return root
	end

	local best = nil
	local bestScore = -math.huge

	for _, obj in ipairs(root:GetDescendants()) do
		if obj:IsA("GuiButton") and isVisibleOnScreen(obj) then
			local n = tostring(obj.Name or ""):lower()
			local t = ""
			pcall(function()
				if obj:IsA("TextButton") then
					t = tostring(obj.Text or ""):lower()
				end
			end)

			local score = 0
			if n == "claim" then score += 300 end
			if n:find("claim") then score += 160 end
			if n:find("check") or n:find("confirm") or n:find("continue") or n:find("ok") then score += 120 end
			if t:find("claim") or t:find("continue") or t:find("ok") then score += 120 end

			pcall(function()
				local c = obj.BackgroundColor3
				if c.G > 0.55 and c.R > 0.35 and c.B < 0.45 then
					score += 70
				end
			end)

			local size = obj.AbsoluteSize
			if size.X >= 50 and size.Y >= 35 then score += 30 end
			score += math.floor(math.clamp(size.X * size.Y / 2500, 0, 40))

			if score > bestScore then
				bestScore = score
				best = obj
			end
		end
	end

	return best
end

function getBestVisualClickObject(root)
	if not root or not root:IsA("GuiObject") then return nil end

	local best = nil
	local bestScore = -math.huge

	local function scoreObj(obj)
		if not obj:IsA("GuiObject") or not isVisibleOnScreen(obj) then return end
		local size = obj.AbsoluteSize
		if size.X < 35 or size.Y < 25 then return end

		local score = 0
		local name = tostring(obj.Name or ""):lower()
		if name:find("claim") or name:find("check") or name:find("confirm") or name:find("button") then
			score += 120
		end

		pcall(function()
			local c = obj.BackgroundColor3
			if c.G > 0.55 and c.R > 0.35 and c.B < 0.50 then
				score += 220
			end
		end)

		pcall(function()
			if obj:IsA("ImageLabel") or obj:IsA("ImageButton") then
				local c = obj.ImageColor3
				if c.G > 0.55 and c.R > 0.35 and c.B < 0.55 then
					score += 180
				end
			end
		end)

		local pos = obj.AbsolutePosition
		score += math.clamp(pos.Y / 10, 0, 90)
		score += math.clamp((size.X * size.Y) / 3500, 0, 70)

		if score > bestScore then
			bestScore = score
			best = obj
		end
	end

	scoreObj(root)
	for _, obj in ipairs(root:GetDescendants()) do
		scoreObj(obj)
	end

	return best
end


function EtherHubCore.GetPetNameLevelLocks()
	normalizePetNameLevelLock()
	local data = getPlayerData("all")
	if type(data) == "table" and type(data.pets) == "table" and type(prunePetNameLevelLocks) == "function" then
		prunePetNameLevelLocks(data, true)
	end
	return petNameLevelLock
end

function EtherHubCore.SetPetNameLevelLock(key, value)
	normalizePetNameLevelLock()
	key = tostring(key or "")
	if key ~= "" then
		if value == true then
			petNameLevelLock[key] = true
		else
			petNameLevelLock[key] = nil
		end
		saveConfig()
	end
	return petNameLevelLock[key] == true
end

function EtherHubCore.ClearPetNameLevelLocks()
	normalizePetNameLevelLock()
	local changed = false
	for key in pairs(petNameLevelLock) do
		petNameLevelLock[key] = nil
		changed = true
	end
	if changed then
		saveConfig()
	end
	return true
end

function EtherHubCore.GetPetInventoryLockList()
	normalizePetNameLevelLock()
	local data = getPlayerData("all")
	local list = {}
	if type(data) ~= "table" or type(data.pets) ~= "table" then
		return list
	end

	if type(prunePetNameLevelLocks) == "function" then
		prunePetNameLevelLocks(data, true)
	end

	local grouped = {}
	for petId in pairs(data.pets) do
		petId = tostring(petId)
		local name = getPetDisplayName(data, petId)
		local level = getPetLevel(data, petId)
		local key = getPetNameLevelLockKey(data, petId)
		local tier = getPetTierName(data, petId)
		local score = getPetScore(data, petId)

		if not grouped[key] then
			grouped[key] = {
				key = key,
				name = name,
				level = level,
				tier = tier,
				count = 0,
				locked = petNameLevelLock[key] == true,
				bestScore = score,
			}
		end
		grouped[key].count += 1
		grouped[key].bestScore = math.max(tonumber(grouped[key].bestScore) or 0, tonumber(score) or 0)
	end

	for _, item in pairs(grouped) do
		list[#list + 1] = item
	end

	table.sort(list, function(a, b)
		if a.locked ~= b.locked then return a.locked == true end
		if tostring(a.name) ~= tostring(b.name) then return tostring(a.name) < tostring(b.name) end
		return (tonumber(a.level) or 0) > (tonumber(b.level) or 0)
	end)

	return list
end


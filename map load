local function getSafeParent()
    if type(gethui) == "function" then
        local ok, hui = pcall(gethui)
        if ok and hui then
            return hui
        end
    end

    local ok, cg = pcall(function()
        return game:GetService("CoreGui")
    end)

    if ok and cg then
        return cg
    end

    return PlayerGui
end


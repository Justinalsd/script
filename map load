local function notify(title, message, color, duration)
    duration = duration or 5
    color = color or THEME.Accent

    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 92)
    frame.BackgroundColor3 = THEME.Card
    frame.BackgroundTransparency = 0.02
    frame.BorderSizePixel = 0
    frame.LayoutOrder = -math.floor(os.clock() * 1000)
    frame.Position = UDim2.new(1, 30, 0, 0)
    frame.Parent = ToastHolder

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 12)
    corner.Parent = frame

    local stroke = Instance.new("UIStroke")
    stroke.Color = color
    stroke.Thickness = 2
    stroke.Transparency = 0.05
    stroke.Parent = frame

    local bar = Instance.new("Frame")
    bar.Size = UDim2.new(0, 5, 1, -18)
    bar.Position = UDim2.new(0, 10, 0, 9)
    bar.BackgroundColor3 = color
    bar.BorderSizePixel = 0
    bar.Parent = frame

    local barCorner = Instance.new("UICorner")
    barCorner.CornerRadius = UDim.new(1, 0)
    barCorner.Parent = bar

    local titleLabel = Instance.new("TextLabel")
    titleLabel.BackgroundTransparency = 1
    titleLabel.Size = UDim2.new(1, -36, 0, 24)
    titleLabel.Position = UDim2.new(0, 24, 0, 10)
    titleLabel.Text = tostring(title)
    titleLabel.TextColor3 = THEME.White
    titleLabel.Font = Enum.Font.GothamBold
    titleLabel.TextSize = UserInputService.TouchEnabled and 13 or 14
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.TextTruncate = Enum.TextTruncate.AtEnd
    titleLabel.Parent = frame

    local msgLabel = Instance.new("TextLabel")
    msgLabel.BackgroundTransparency = 1
    msgLabel.Size = UDim2.new(1, -36, 0, 48)
    msgLabel.Position = UDim2.new(0, 24, 0, 36)
    msgLabel.Text = tostring(message)
    msgLabel.TextColor3 = Color3.fromRGB(245, 248, 255)
    msgLabel.Font = Enum.Font.GothamMedium
    msgLabel.TextSize = UserInputService.TouchEnabled and 11 or 12
    msgLabel.TextXAlignment = Enum.TextXAlignment.Left
    msgLabel.TextYAlignment = Enum.TextYAlignment.Top
    msgLabel.TextWrapped = true
    msgLabel.Parent = frame

    TweenService:Create(frame, TweenInfo.new(0.25, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
        Position = UDim2.new(0, 0, 0, 0)
    }):Play()

    task.delay(duration, function()
        if not frame.Parent then
            return
        end

        TweenService:Create(frame, TweenInfo.new(0.25, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
            Position = UDim2.new(1, 30, 0, 0),
            BackgroundTransparency = 1
        }):Play()

        task.delay(0.3, function()
            if frame then
                frame:Destroy()
            end
        end)
    end)
end

local function getMapDisplayName(placeId)
    placeId = tonumber(placeId) or game.PlaceId

    if MAP_NAMES and MAP_NAMES[placeId] then
        return MAP_NAMES[placeId]
    end

    local ok, info = pcall(function()
        return MarketplaceService:GetProductInfo(placeId)
    end)

    if ok and type(info) == "table" and info.Name and tostring(info.Name) ~= "" then
        return tostring(info.Name)
    end

    return "Unknown Map"
end

local function httpGet(url)
    if type(url) ~= "string" or url == "" then
        return false, "Invalid script URL"
    end

    local ok, result = pcall(function()
        return game:HttpGet(url, true)
    end)

    if ok and type(result) == "string" and result ~= "" then
        return true, result
    end

    return false, tostring(result or "HttpGet failed")
end

local function runSource(source, mapName)
    local loader = loadstring or load

    if type(loader) ~= "function" then
        return false, "loadstring/load is not available in this executor"
    end

    local fn, compileErr = loader(source)

    if type(fn) ~= "function" then
        return false, "Compile error: " .. tostring(compileErr)
    end

    local ok, runtimeErr = pcall(fn)

    if not ok then
        return false, "Runtime error in " .. tostring(mapName) .. ": " .. tostring(runtimeErr)
    end

    return true
end

local function loadForCurrentMap()
    local placeId = game.PlaceId
    local config = MAP_CONFIG[placeId]

    if not config then
        local mapName = getMapDisplayName(placeId)

        notify(
            "Unsupported Map",
            mapName .. " • Unsupported PlaceId: " .. tostring(placeId),
            THEME.Red,
            8
        )

        warn("[What HUB Loader] Unsupported PlaceId:", placeId)
        return false
    end

    local mapName = config.Name or getMapDisplayName(placeId)
    local scriptUrl = config.Url

    notify("Map Detected", mapName .. " • PlaceId: " .. tostring(placeId), THEME.Accent2, 4.5)
    notify("Loading Script", "Loading script for " .. mapName .. "...", THEME.Green, 3.5)

    task.spawn(function()
        local getOk, sourceOrErr = httpGet(scriptUrl)

        if not getOk then
            notify("HttpGet Error", tostring(sourceOrErr), THEME.Red, 8)
            warn("[What HUB Loader] HttpGet error:", sourceOrErr)
            return
        end

        local runOk, runErr = runSource(sourceOrErr, mapName)

        if runOk then
            notify("Script Loaded", "Loaded successfully for " .. mapName .. ".", THEME.Green, 5)
            print("[What HUB Loader] Script loaded successfully:", mapName, "PlaceId:", placeId)
        else
            notify("Script Error", tostring(runErr), THEME.Red, 8)
            warn("[What HUB Loader] Script error:", runErr)
        end
    end)

    return true
end

loadForCurrentMap()

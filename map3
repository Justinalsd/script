local function acquireMarker()
    if #markerPool > 0 then return table.remove(markerPool) end
    local bb  = Instance.new("BillboardGui")
    bb.Name="MineDisplayMarker"; bb.AlwaysOnTop=true; bb.MaxDistance=MARKER_MAX_DIST

    local dot = Instance.new("Frame")
    dot.Name="Dot"; dot.Size=UDim2.new(1,0,1,0)
    dot.BorderSizePixel=0; dot.BackgroundTransparency=0.05
    local uc=Instance.new("UICorner"); uc.CornerRadius=UDim.new(1,0); uc.Parent=dot
    local us=Instance.new("UIStroke"); us.Thickness=2
        us.Color=Color3.fromRGB(255,255,255); us.Transparency=0.25; us.Parent=dot
    dot.Parent=bb

    local lbl=Instance.new("TextLabel")
    lbl.Name="ProbLabel"; lbl.Size=UDim2.new(1,0,1,0)
    lbl.BackgroundTransparency=1; lbl.TextColor3=Color3.fromRGB(255,255,255)
    lbl.Font=Enum.Font.GothamBold
    lbl.TextStrokeTransparency=0.1; lbl.TextStrokeColor3=Color3.fromRGB(0,0,0)
    lbl.Parent=dot

    return {bb=bb, dot=dot, lbl=lbl}
end

local function releaseMarker(e)
    if e.bb then e.bb.Parent=nil end
    e.dot.Rotation=0
    table.insert(markerPool, e)
end

local function clearMarkerOn(part)
    if not part then return end
    local e=activeMarkers[part]
    if e then releaseMarker(e); activeMarkers[part]=nil; markerCache[part]=nil end
end

local function clearAllMarkers()
    for part,e in pairs(activeMarkers) do releaseMarker(e); activeMarkers[part]=nil; markerCache[part]=nil end
end

local function clearFarMarkers(pp)
    local lim=PROCESS_RADIUS+PROCESS_MARGIN
    for part,e in pairs(activeMarkers) do
        if not part or not part.Parent or (part.Position-pp).Magnitude>lim then
            releaseMarker(e); activeMarkers[part]=nil; markerCache[part]=nil
        end
    end
end


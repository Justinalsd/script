local function setupHook()
    if hookInstalled then return end
    local ev=RepStorage:FindFirstChild("Events"); if not ev then return end
    local fe=ev:FindFirstChild("FlagEvents");    if not fe then return end
    placeFlagEvent=fe:FindFirstChild("PlaceFlag"); if not placeFlagEvent then return end
    
    local old
    old=hookmetamethod(game,"__namecall",function(self,...)
        if self==placeFlagEvent and getnamecallmethod()=="FireServer" then
            local a={...}
            if #a >= 2 then
                local pw=a[2]
                if (type(pw)=="string" or type(pw)=="number") and not capturedPassword then
                    capturedPassword=tostring(pw)
                    needsFirstFlag = false
                    showNotification("✅ Auto-Flag Activated", "Password captured!", 5, "success")
                end
            end
        end
        return old(self,...)
    end)
    hookInstalled=true
end

local function setupHookFallback()
    if hookInstalled or not placeFlagEvent then return end
    if typeof(hookfunction)=="function" then
        local oldFS=hookfunction(placeFlagEvent.FireServer,function(self,...)
            local a={...}
            if #a >= 2 then
                local pw=a[2]
                if (type(pw)=="string" or type(pw)=="number") and not capturedPassword then
                    capturedPassword=tostring(pw)
                    needsFirstFlag = false
                    showNotification("✅ Auto-Flag Activated", "Password captured!", 5, "success")
                end
            end
            return oldFS(self,...)
        end)
        hookInstalled=true
    end
end


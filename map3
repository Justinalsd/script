-- Auto Color
-- ============================================
local function disconnectHooks()
    for _,c in ipairs(autoConns) do pcall(function() c:Disconnect() end) end; autoConns={}
end

local function scheduleReload()
    if not solverEnabled or not autoColorEnabled or autoScheduled then return end
    autoScheduled=true
    task.delay(AUTO_DEBOUNCE,function()
        autoScheduled=false
        if not solverEnabled or not autoColorEnabled then return end
        if isAnalyzing then scheduleReload(); return end
        analyzeNearby("auto")
    end)
end

local function hookPart(part)
    if not part or not part:IsA("BasePart") then return end
    if not nearPlayer(part.Position,PROCESS_MARGIN) then return end
    local function hookNG(ng)
        if not ng then return end
        local tl=ng:FindFirstChild("TextLabel")
        if tl then table.insert(autoConns,tl:GetPropertyChangedSignal("Text"):Connect(scheduleReload)) end
        table.insert(autoConns,ng.ChildAdded:Connect(function(c)
            if c.Name=="TextLabel" then task.wait(0.03); hookNG(ng) end; scheduleReload()
        end))
        table.insert(autoConns,ng.ChildRemoved:Connect(scheduleReload))
    end
    hookNG(part:FindFirstChild("NumberGui"))
    table.insert(autoConns,part.ChildAdded:Connect(function(c)
        if c.Name=="NumberGui" then task.wait(0.03); hookNG(c) end; scheduleReload()
    end))
    table.insert(autoConns,part.ChildRemoved:Connect(scheduleReload))
end

local function rebuildHooks()
    disconnectHooks()
    for _,p in ipairs(FLAG_FOLDER:GetChildren()) do hookPart(p) end
    table.insert(autoConns,FLAG_FOLDER.ChildAdded:Connect(function(p)
        task.wait(0.08)
        if solverEnabled and nearPlayer(p.Position,PROCESS_MARGIN) then hookPart(p); scheduleReload() end
    end))
    table.insert(autoConns,FLAG_FOLDER.ChildRemoved:Connect(scheduleReload))
    lastHookPos=getPos()
end

local function startAutoColor()
    if not solverEnabled or autoColorEnabled then return end
    autoColorEnabled=true; lastScanPos=nil; lastHookPos=nil
    if autoButton then autoButton.Text="Auto: ON"; autoButton.BackgroundColor3=Color3.fromRGB(0,150,70) end
    setMode("Auto ON"); rebuildHooks()
    task.spawn(function()
        while solverEnabled and autoColorEnabled do
            local pp=getPos()
            if pp then
                if lastHookPos and (pp-lastHookPos).Magnitude>=HOOK_REBUILD_DIST then rebuildHooks() end
                if lastScanPos and (pp-lastScanPos).Magnitude>=MOVE_RELOAD_DIST then
                    lastScanPos=pp; scheduleReload()
                elseif not lastScanPos then lastScanPos=pp end
            end
            task.wait(0.18)
        end
    end)
    scheduleReload()
end

local function stopAutoColor()
    autoColorEnabled=false; autoScheduled=false; lastScanPos=nil; lastHookPos=nil
    disconnectHooks(); clearFlagQueue()
    if autoButton then autoButton.Text="Auto: OFF"; autoButton.BackgroundColor3=Color3.fromRGB(55,55,65) end
    setMode("Idle"); setStatus("Auto Color OFF")
end


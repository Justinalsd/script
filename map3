local cellReadCache = {}

local function readCell(part)
    local cached = cellReadCache[part]
    if cached and cached.timestamp and tick() - cached.timestamp < 0.3 then return cached.data end
    
    local ng=part:FindFirstChild("NumberGui")
    local tl=ng and ng:FindFirstChild("TextLabel")
    local txt=tl and tl.Text or ""
    local num=tonumber(txt)
    local rev=ng and tl and (txt=="" or num~=nil)
    local result = {number=num, flagged=isFlagVerified(part), revealed=rev and true or false, isNormal=rev and txt=="" or false, isUnopened=not (ng and tl and (txt=="" or num~=nil))}
    cellReadCache[part] = {data=result, timestamp=tick()}
    return result
end

local function buildBoardChunked()
    local pp = getPos()
    if not pp then board = {}; partToIndex = {}; return 0 end

    local nearby = {}
    for _, p in ipairs(FLAG_FOLDER:GetChildren()) do
        if p:IsA("BasePart") then
            local d = (p.Position - pp).Magnitude
            if d <= PROCESS_RADIUS + PROCESS_MARGIN then
                table.insert(nearby, {part=p, dist=d})
            else
                clearMarkerOn(p)
            end
        end
    end

    table.sort(nearby, function(a,b)
        if math.abs(a.part.Position.X - b.part.Position.X) > 1 then
            return a.part.Position.X < b.part.Position.X
        end
        return a.part.Position.Z < b.part.Position.Z
    end)

    board = {}
    partToIndex = {}

    for i = 1, #nearby do
        local item = nearby[i]
        local s = readCell(item.part)
        board[i] = {
            part=item.part, index=i, dist=item.dist,
            insideMain = item.dist <= PROCESS_RADIUS,
            edgeFactor = math.clamp(1-(item.dist-PROCESS_RADIUS*0.7)/(PROCESS_RADIUS*0.3),0.6,1.0),
            number=s.number, flagged=s.flagged, revealed=s.revealed,
            isNormal=s.isNormal, isUnopened=s.isUnopened,
            neighbors={}, safeProbability=nil, mineProbability=nil,
            isFrontier=false, isLocalCertain=false
        }
        partToIndex[item.part] = i
        if i % 50 == 0 then task.wait() end
    end

    local CELL_SIZE = NEIGHBOR_DIST + 1
    local grid = {}

    local function gridKey(pos)
        local gx = math.floor(pos.X / CELL_SIZE)
        local gz = math.floor(pos.Z / CELL_SIZE)
        return gx * 100000 + gz
    end

    for i, cell in ipairs(board) do
        local k = gridKey(cell.part.Position)
        if not grid[k] then grid[k] = {} end
        table.insert(grid[k], i)
    end

    local offsets = {}
    for dx = -1, 1 do
        for dz = -1, 1 do
            table.insert(offsets, {dx=dx, dz=dz})
        end
    end

    for i = 1, #board do
        local pos = board[i].part.Position
        local gx  = math.floor(pos.X / CELL_SIZE)
        local gz   = math.floor(pos.Z / CELL_SIZE)

        for _, off in ipairs(offsets) do
            local k = (gx + off.dx) * 100000 + (gz + off.dz)
            local bucket = grid[k]
            if bucket then
                for _, j in ipairs(bucket) do
                    if i ~= j and (pos - board[j].part.Position).Magnitude < NEIGHBOR_DIST then
                        table.insert(board[i].neighbors, j)
                    end
                end
            end
        end

        if i % 50 == 0 then task.wait() end
    end

    totalFlagsOnBoard = 0
    for _, c in ipairs(board) do if c.flagged then totalFlagsOnBoard += 1 end end

    return #board
end

local function resetProb()
    for _,c in ipairs(board) do c.safeProbability=nil; c.mineProbability=nil; c.isFrontier=false; c.isLocalCertain=false end
end


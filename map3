local function fireFlag(part)
    if not capturedPassword or not placeFlagEvent then return false end
    local ok = pcall(function() placeFlagEvent:FireServer(part, capturedPassword, true) end)
    return ok
end

local function waitFlagState(part, wantFlag, timeout)
    local t0 = tick()
    while tick() - t0 < timeout do
        if isFlagVerified(part) == wantFlag then return true end
        task.wait(0.1)
    end
    return false
end

local function preCheckFlag(part)
    if not part or not part.Parent then return "no_part" end
    if isFlagVerified(part) then return "already_flagged" end
    local ng  = part:FindFirstChild("NumberGui")
    local tl  = ng and ng:FindFirstChild("TextLabel")
    local txt = tl and tl.Text or ""
    if ng and tl and (txt == "" or tonumber(txt) ~= nil) then return "not_unopened" end
    return "ok"
end

local function queueFlag(cell, priority, distance)
    priority = priority or 0
    distance = distance or 999
    for _,q in ipairs(flagQueue) do if q.part==cell.part then return false end end
    if #flagQueue >= FLAG_QUEUE_MAX then return false end
    table.insert(flagQueue, {part=cell.part, retries=0, mode="flag", priority=priority, distance=distance})
    return true
end

local function getFlagDelay(dist)
    if dist <= NEAR_DIST_FAST then return NEAR_FLAG_DELAY end
    if dist <= MID_DIST_FAST then return MID_FLAG_DELAY end
    return BASE_FLAG_DELAY
end

local function countNearbyMines(cellIdx, radius)
    local count = 0
    local c = board[cellIdx]
    if not c then return 0 end
    local pos = c.part.Position
    for _, other in ipairs(board) do
        if other.index ~= cellIdx and other.mineProbability and other.mineProbability >= 0.999 then
            if (other.part.Position - pos).Magnitude <= radius then count += 1 end
        end
    end
    return count
end

local function calculatePriority(cellIdx, dist)
    local cluster = countNearbyMines(cellIdx, CLUSTER_RADIUS)
    local distScore = math.clamp(1 - (dist / autoFlagRange), 0, 1) * 100
    local clusterScore = cluster * 50
    return distScore + clusterScore
end

local function clearFlagQueue() flagQueue = {}; isFlagging = false end

local function processFlagQueue()
    if isFlagging or #flagQueue == 0 or not capturedPassword then return end
    if needsFirstFlag then return end
    isFlagging = true
    task.spawn(function()
        while #flagQueue > 0 and solverEnabled and autoFlagEnabled do
            table.sort(flagQueue, function(a, b) return (a.priority or 0) > (b.priority or 0) end)
            local item = flagQueue[1]
            local part = item.part
            local preRes = preCheckFlag(part)
            if preRes ~= "ok" then table.remove(flagQueue, 1); continue end
            local pp = getPos(); if not pp then break end
            local currentDist = (part.Position - pp).Magnitude
            if currentDist > autoFlagRange then table.remove(flagQueue, 1); continue end
            if flagDebounce[part] and tick() - flagDebounce[part] < 1.5 then table.remove(flagQueue, 1); continue end
            item.distance = currentDist
            item.priority = calculatePriority(partToIndex[part], currentDist)
            local ok = fireFlag(part)
            if ok then
                flagDebounce[part] = tick()
                task.wait(FLAG_VERIFY_DELAY)
                local verified = waitFlagState(part, true, FLAG_VERIFY_TOUT)
                if verified then
                    flagsPlaced += 1; dbRecord(part); setCooldown(part); table.remove(flagQueue, 1)
                else
                    item.retries += 1
                    if item.retries >= FLAG_RETRY_MAX then flagsFailed += 1; table.remove(flagQueue, 1) end
                end
            else
                item.retries += 1
                if item.retries >= FLAG_RETRY_MAX then flagsFailed += 1; table.remove(flagQueue, 1) end
            end
            task.wait(getFlagDelay(item.distance or currentDist))
        end
        isFlagging = false
    end)
end

local function autoFlagMinesOnly100()
    if not solverEnabled or not autoFlagEnabled or not capturedPassword or needsFirstFlag then return end
    local pp = getPos(); if not pp then return end
    local n = 0
    for _, cell in ipairs(board) do
        if cell.revealed and cell.number ~= nil then
            local unopened, flagCount = {}, 0
            for _, ni in ipairs(cell.neighbors) do
                local c = board[ni]
                if c and c.isUnopened then
                    if c.flagged then flagCount += 1 else table.insert(unopened, ni) end
                end
            end
            local rem = cell.number - flagCount
            if rem == #unopened and rem > 0 then
                for _, idx in ipairs(unopened) do
                    local c = board[idx]
                    if c and c.isUnopened and not isFlagVerified(c.part) and (c.part.Position - pp).Magnitude <= autoFlagRange then
                        local dist = (c.part.Position - pp).Magnitude
                        local priority = calculatePriority(idx, dist)
                        if queueFlag(c, priority, dist) then n += 1 end
                    end
                end
            end
        end
    end
    if n > 0 then processFlagQueue() end
end


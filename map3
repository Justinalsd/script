-- ============================================
-- Color LUT (Pre-cached)
-- ============================================
local COLOR_LUT = {}
do
    for i = 0, 100 do
        local t = i/100
        local r,g,b
        if t <= 0.5 then
            local s=t/0.5; r=220; g=math.floor(s*200); b=math.floor(s*40)
        else
            local s=(t-0.5)/0.5
            r=math.floor(220*(1-s)); g=math.floor(200+s*20); b=math.floor(40+s*40)
        end
        COLOR_LUT[i] = Color3.fromRGB(r,g,b)
    end
end

local function probColor(p)
    return COLOR_LUT[math.clamp(math.floor(p*100+0.5),0,100)]
end



-- ============================================
-- Constraints (OPTIMIZED - SKIP EARLY)
-- ============================================
local function buildConstraints()
    local cons = {}
    local limit = 0
    for _, cell in ipairs(board) do
        if limit >= MAX_CONFIGS then break end
        if cell.revealed and cell.number ~= nil then
            local unopened, flagCount = {}, 0
            for _, ni in ipairs(cell.neighbors) do
                local n = board[ni]
                if n and n.isUnopened then
                    if useFlagsInCalc and n.flagged then flagCount += 1
                    else table.insert(unopened, ni); n.isFrontier = true end
                end
            end
            local rem = useFlagsInCalc and (cell.number - flagCount) or cell.number
            if #unopened > 0 and rem >= 0 and rem <= #unopened then
                table.insert(cons, {cells=unopened, mines=rem})
                limit += 1
            end
        end
    end
    return cons
end

local function markSafe(idx, prob, isCertain)
    local c=board[idx]; if not c or not c.isUnopened then return false end
    if isCertain then c.isLocalCertain = true end
    if prob>(c.safeProbability or -1) then c.safeProbability=prob; c.mineProbability=1-prob; return true end
    return false
end

local function markMine(idx, prob, isCertain)
    local c=board[idx]; if not c or not c.isUnopened then return false end
    if isCertain then c.isLocalCertain = true end
    if prob>(c.mineProbability or -1) then c.mineProbability=prob; c.safeProbability=1-prob; return true end
    return false
end

local function isSubset(a,b) for _,v in ipairs(a) do if not listHas(b,v) then return false end end return true end
local function diffSet(big,small)
    local d={}; for _,v in ipairs(big) do if not listHas(small,v) then table.insert(d,v) end end return d
end

-- ⚡ ULTRA FAST BASIC SUBSET - ONLY 1 ITERATION
local function applyBasicSubset(cons)
    for _,con in ipairs(cons) do
        if con.mines<=0 then
            for _,i in ipairs(con.cells) do markSafe(i,1,true) end
        elseif con.mines==#con.cells then
            for _,i in ipairs(con.cells) do markMine(i,1,true) end
        else
            local mp=con.mines/#con.cells
            for _,i in ipairs(con.cells) do
                if board[i] and board[i].safeProbability==nil then markSafe(i,1-mp,false) end
            end
        end
    end
    
    local cmp=0
    for a=1,#cons do
        if cmp>=150 then break end  -- ⚡ REDUCED from 300
        local A=cons[a]
        for b=a+1,#cons do
            cmp+=1; if cmp>=150 then break end
            local B=cons[b]
            if #A.cells<=#B.cells and isSubset(A.cells,B.cells) then
                local d=diffSet(B.cells,A.cells); local md=B.mines-A.mines
                if #d>0 then
                    if md<=0 then for _,i in ipairs(d) do markSafe(i,1,true) end
                    elseif md==#d then for _,i in ipairs(d) do markMine(i,1,true) end end
                end
            end
        end
    end
end

local function splitComponents(cons)
    if #cons == 0 then return {} end
    local varToCons={}
    for ci,con in ipairs(cons) do
        for _,vi in ipairs(con.cells) do
            varToCons[vi]=varToCons[vi] or {}; table.insert(varToCons[vi],ci)
        end
    end
    local visited,components={},{}
    for start=1,#cons do
        if not visited[start] then
            local queue,qh,cSet,vSet={start},1,{},{}
            visited[start]=true
            while qh<=#queue do
                local ci=queue[qh]; qh+=1; cSet[ci]=true
                for _,vi in ipairs(cons[ci].cells) do
                    vSet[vi]=true
                    for _,nc in ipairs(varToCons[vi] or {}) do
                        if not visited[nc] then visited[nc]=true; table.insert(queue,nc) end
                    end
                end
            end
            local cc,cv={},{}
            for ci in pairs(cSet) do table.insert(cc,cons[ci]) end
            for vi in pairs(vSet) do table.insert(cv,vi) end
            table.insert(components,{constraints=cc,vars=cv})
        end
    end
    return components
end

-- ⚡ ULTRA FAST COMPONENT SOLVER
local function solveComponentFixed(comp)
    local vars,cons=comp.vars,comp.constraints
    if #vars==0 then return false end
    local varPos={}
    for pos,idx in ipairs(vars) do varPos[idx]=pos end
    local conData={}
    for _,con in ipairs(cons) do
        local pos={}
        for _,idx in ipairs(con.cells) do local p=varPos[idx]; if p then table.insert(pos,p) end end
        table.insert(conData,{positions=pos,mines=con.mines})
    end
    local n=#vars
    local assignment=table.create(n,0); local mineCounts=table.create(n,0)
    local validCount=0; local limitHit=false

    local function canContinue(depth)
        for _,cd in ipairs(conData) do
            local assigned,unknown=0,0
            for _,p in ipairs(cd.positions) do
                if p<=depth then assigned+=assignment[p] else unknown+=1 end
            end
            if assigned>cd.mines or assigned+unknown<cd.mines then return false end
        end
        return true
    end

    local function isValid()
        for _,cd in ipairs(conData) do
            local s=0
            for _,p in ipairs(cd.positions) do s += assignment[p] end
            if s~=cd.mines then return false end
        end
        return true
    end

    if n<=MAX_COMPONENT then
        local function dfs(pos)
            if limitHit then return end
            if validCount>=MAX_CONFIGS then limitHit=true; return end
            if pos>n then
                if isValid() then
                    validCount+=1; for i=1,n do if assignment[i]==1 then mineCounts[i]+=1 end end
                end
                return
            end
            assignment[pos]=0; if canContinue(pos) then dfs(pos+1) end
            assignment[pos]=1; if canContinue(pos) then dfs(pos+1) end
            assignment[pos]=0
        end
        dfs(1)
    else
        local mr=math.random
        for _=1,SAMPLING_CONFIGS do
            for i=1,n do assignment[i]=mr(0,1) end
            if isValid() then
                validCount+=1; for i=1,n do if assignment[i]==1 then mineCounts[i]+=1 end end
            end
        end
    end

    if validCount<=0 then return false end
    for pos,idx in ipairs(vars) do
        local mp=mineCounts[pos]/validCount
        markSafe(idx,1-mp,false)
        markMine(idx,mp,false)
    end
    return true
end

local function applyOffFrontierProb(globalRem)
    if not globalRem or globalRem<=0 then return end
    local off,knownMines={},0
    for _,c in ipairs(board) do
        if c.isUnopened and c.insideMain then
            if not c.isFrontier then table.insert(off,c.index)
            elseif c.mineProbability and c.mineProbability>=0.999 then knownMines+=1 end
        end
    end
    local rem=globalRem-knownMines
    if #off>0 and rem>0 then
        local mp=math.clamp(rem/#off,0,1)
        for _,idx in ipairs(off) do
            if board[idx] and board[idx].safeProbability==nil then markSafe(idx,1-mp,false) end
        end
    elseif #off>0 and rem<=0 then
        for _,idx in ipairs(off) do markSafe(idx,1,false) end
    end
end

-- ⚡ ULTRA FAST MULTI-PASS
local function multiPassSolveBalanced(cons)
    setMode("Solving...")
    applyBasicSubset(cons)
    local comps = splitComponents(cons)
    for i = 1, math.min(#comps, 3) do  -- ⚡ ONLY TOP 3 COMPONENTS
        if not solverEnabled then return end
        solveComponentFixed(comps[i])
    end
    setMode("Done")
end

-- ============================================
-- Display (BATCH OPTIMIZED)
-- ============================================
local function displayResults()
    if not solverEnabled then return end
    local pp=getPos(); if not pp then return end
    clearFarMarkers(pp)
    for _,cell in ipairs(board) do
        if not cell.isUnopened or isFlagVerified(cell.part) then clearMarkerOn(cell.part) end
    end
    
    local ct={s100=0,s80=0,s70=0,s60=0,s40=0,s30=0,mine=0,shown=0,hidden=0,certain=0}
    local toShow = {}
    
    for _,cell in ipairs(board) do
        if not cell.insideMain or not cell.isUnopened or isFlagVerified(cell.part) then continue end
        ct.hidden+=1
        if not showAllSafe and not cell.isFrontier then continue end
        
        local sp=cell.safeProbability
        local ef=cell.edgeFactor or 1.0
        if sp then sp=0.6+(sp-0.6)*ef end
        
        if sp and sp>=0.999 then
            ct.s100+=1; ct.shown+=1
            if cell.isLocalCertain then ct.certain+=1 end
            table.insert(toShow, {part=cell.part, type="safe"})
        elseif sp and sp>=safeThreshold then
            if     sp>=0.80 then ct.s80+=1
            elseif sp>=0.70 then ct.s70+=1
            elseif sp>=0.60 then ct.s60+=1
            elseif sp>=0.40 then ct.s40+=1
            else ct.s30+=1 end
            ct.shown+=1
            table.insert(toShow, {part=cell.part, type="dot", prob=sp})
        elseif cell.mineProbability and cell.mineProbability>=0.999 then
            ct.mine+=1; ct.shown+=1
            if cell.isLocalCertain then ct.certain+=1 end
            table.insert(toShow, {part=cell.part, type="mine"})
        else
            clearMarkerOn(cell.part)
        end
    end
    
    for _, marker in ipairs(toShow) do
        if marker.type == "safe" then
            showSafeSticker(marker.part)
        elseif marker.type == "mine" then
            showMineSticker(marker.part)
        elseif marker.type == "dot" then
            showDot(marker.part, marker.prob)
        end
    end
    
    setStatus("Near:"..#board.." H:"..ct.hidden.." Mk:"..ct.shown.." | OK:"..ct.s100.." 80:"..ct.s80.." 70:"..ct.s70.." 60:"..ct.s60.." 40:"..ct.s40.." 30:"..ct.s30.." Mine:"..ct.mine.." [OK:"..ct.certain.."]")
    if autoFlagEnabled and not needsFirstFlag then
        autoFlagMinesOnly100()
    end
end

-- ============================================
-- Analyze (MAIN SOLVER)
-- ============================================
local function analyzeNearby(source)
    if not solverEnabled or isAnalyzing then return end
    isAnalyzing=true
    if analyzeButton then
        analyzeButton.Text="Analyzing..."
        analyzeButton.BackgroundColor3=Color3.fromRGB(160,70,30)
    end
    setMode(source=="auto" and "Auto" or "Reading...")
    local count = buildBoardChunked()
    resetProb()
    if count == 0 then
        setStatus("No cells nearby"); setMode("Idle"); isAnalyzing=false
        if analyzeButton then analyzeButton.Text="Analyze Nearby"; analyzeButton.BackgroundColor3=Color3.fromRGB(0,125,210) end
        return
    end
    local cons = buildConstraints()
    if #cons > 0 then
        multiPassSolveBalanced(cons)
    end
    local totalMines=totalMinesOnBoard or tryReadTotalMines()
    if totalMines then
        local fc=0; for _,c in ipairs(board) do if c.flagged then fc+=1 end end
        applyOffFrontierProb(totalMines-fc)
    end
    if solverEnabled then
        setMode(autoColorEnabled and "Auto ON" or "Done")
        displayResults()
    end
    isAnalyzing=false
    if analyzeButton then analyzeButton.Text="Analyze Nearby"; analyzeButton.BackgroundColor3=Color3.fromRGB(0,125,210) end
end


clearAllMarkers(); flagDebounce={}

task.spawn(function()
    setupHook()
    if not hookInstalled then setupHookFallback() end
    showNotification("🎮 Mine Solver Ready", "Flag one cell manually to unlock auto-flag feature", 6, "warning")
end)

createGui()
createMobileToggle()
